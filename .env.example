# Copy this file to ".env" and fill in your real values. NEVER put real
# secrets in this example file — it gets committed to GitHub.

PORT=5000
SESSION_SECRET=replace-with-a-long-random-string
ADMIN_PASSWORD=changeme

# --- Football data for the admin "Import fixtures" button ---
# Set ONE provider. If both are set, API_FOOTBALL_KEY wins.

# Provider A (recommended for WC 2026): API-Sports / api-football.com
# Sign up + copy key from https://dashboard.api-football.com  (free: 100 req/day)
API_FOOTBALL_KEY=
# Optional overrides (defaults: World Cup league=1, season=2026)
API_FOOTBALL_LEAGUE=1
API_FOOTBALL_SEASON=2026

# Provider B: football-data.org  (https://www.football-data.org/client/register)
FOOTBALL_API_KEY=

# How often the app auto-syncs fixtures/live-scores/results from the API.
# Lower = fresher live scores but more API calls (mind your plan's daily quota).
SYNC_INTERVAL_SECONDS=300

# Deadline after which "Predict the Champion" picks lock (ISO 8601).
CHAMPION_LOCK=2026-06-25T23:59:59+01:00

# Firebase: for local dev, place serviceAccountKey.json in the project root.
# For hosting, you can instead set the whole JSON on one line:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account", ...}
