# Copy this file to ".env" and fill in your values.

# Express
PORT=3000
SESSION_SECRET=replace-with-a-long-random-string

# Admin panel password (used at /admin/login)
ADMIN_PASSWORD=changeme

# --- Firebase credentials -------------------------------------------------
# Option A (recommended for local dev): leave this blank and instead place a
#   serviceAccountKey.json file at the project root (see README.md).
#
# Option B (recommended for hosting like Render/Railway/Heroku): paste the
#   entire service account JSON on ONE line below.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...", ...}
