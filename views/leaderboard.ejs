<%- include("partials/head", { title: "Leaderboard · WC 2026 Predictor" }) %>
<%- include("partials/navbar") %>

<%
  function podiumPlace(u, rank) {
    if (!u) return "";
    const cls = rank === 1 ? "gold" : rank === 2 ? "silver" : "bronze";
    const esc = (s) => String(s == null ? "" : s).replace(/[&<>"]/g, (c) =>
      ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
    const ava = u.avatar
      ? '<img class="podium-avatar" src="' + esc(avatarSrc(u.avatar)) + '" alt=""/>'
      : '<span class="podium-avatar d-inline-flex align-items-center justify-content-center"><i class="fa-solid fa-user text-secondary"></i></span>';
    return '<div class="podium-place podium-' + rank + '" data-id="' + esc(u.id) + '" style="cursor:pointer">' +
      '<div class="podium-ava-wrap">' + ava + '<span class="medal medal-' + cls + ' podium-medal">' + rank + '</span></div>' +
      '<div class="podium-name">' + esc(u.username) + '</div>' +
      '<div class="podium-points">' + u.totalPoints + ' ' + esc(t('common.pts')) +
        (u.livePts > 0 ? ' <span class="text-danger"><span class="live-dot"></span>+' + u.livePts + '</span>' : '') + '</div>' +
      '<div class="podium-bar">' + rank + '</div></div>';
  }
%>

<div class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
      <h2 class="fw-bold mb-0"><i class="fa-solid fa-trophy text-accent me-2"></i><%= t('lb.title') %></h2>
      <p class="text-secondary mb-0"><%= users.length %> <%= users.length === 1 ? t('lb.competing1') : t('lb.competingP') %></p>
    </div>
    <div class="input-group search-box">
      <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
      <input id="searchInput" type="text" class="form-control"
             placeholder="<%= t('lb.search') %>" autocomplete="off" />
    </div>
  </div>

  <% if (users.length) { %>
    <div class="card wc-card border-0 mb-4">
      <div class="card-body">
        <div class="podium mb-0">
          <%- podiumPlace(users[1], 2) %>
          <%- podiumPlace(users[0], 1) %>
          <%- podiumPlace(users[2], 3) %>
        </div>
      </div>
    </div>
  <% } %>

  <div class="card wc-card border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0 leaderboard-table">
        <thead>
          <tr>
            <th class="ps-4" style="width:70px;"><%= t('lb.rank') %></th>
            <th style="width:54px;" class="text-center"><i class="fa-solid fa-arrows-up-down"></i></th>
            <th><%= t('lb.player') %></th>
            <th class="text-end pe-4"><%= t('lb.points') %></th>
          </tr>
        </thead>
        <tbody id="leaderboardBody">
          <% users.forEach(function (u) { %>
            <tr class="user-row <%= u.isMe ? 'row-me' : '' %>" data-name="<%= u.username.toLowerCase() %>" data-id="<%= u.id %>" style="cursor:pointer;">
              <td class="ps-4">
                <% if (u.rank === 1) { %>
                  <span class="medal medal-gold">1</span>
                <% } else if (u.rank === 2) { %>
                  <span class="medal medal-silver">2</span>
                <% } else if (u.rank === 3) { %>
                  <span class="medal medal-bronze">3</span>
                <% } else { %>
                  <span class="text-secondary">#<%= u.rank %></span>
                <% } %>
              </td>
              <td class="text-center small fw-bold">
                <% if (u.move > 0) { %>
                  <span class="text-success"><i class="fa-solid fa-caret-up"></i> <%= u.move %></span>
                <% } else if (u.move < 0) { %>
                  <span class="text-danger"><i class="fa-solid fa-caret-down"></i> <%= -u.move %></span>
                <% } else { %>
                  <span class="text-secondary"><i class="fa-solid fa-minus"></i></span>
                <% } %>
              </td>
              <td>
                <% if (u.avatar) { %>
                  <img src="<%= avatarSrc(u.avatar) %>" class="avatar-mini me-2" alt="" />
                <% } else { %>
                  <i class="fa-solid fa-user-circle text-secondary me-2"></i>
                <% } %>
                <span class="fw-semibold"><%= u.username %></span>
                <% if (u.isMe) { %><span class="badge wc-userchip ms-2"><%= t('lb.you') %></span><% } %>
              </td>
              <td class="text-end pe-4 fw-bold text-accent">
                <%= u.totalPoints %><% if (u.livePts > 0) { %> <small class="text-danger fw-bold"><span class="live-dot"></span>+<%= u.livePts %></small><% } else if (u.gained > 0) { %> <small class="text-success fw-bold">+<%= u.gained %></small><% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <div id="noResults" class="text-center text-secondary py-4 d-none">
      <i class="fa-solid fa-user-slash me-1"></i> <%= t('lb.noMatch') %>
    </div>
  </div>
</div>

<!-- User profile modal -->
<div class="modal fade" id="userModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
    <div class="modal-content wc-card border-0">
      <div class="modal-header">
        <h5 class="modal-title fw-bold d-flex align-items-center gap-2" id="userModalTitle"><%= t('profile.summary') %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="userLoading" class="text-center text-secondary py-4"><i class="fa-solid fa-spinner fa-spin me-1"></i> …</div>
        <div id="userContent" class="d-none">
          <div class="row g-2 mb-3" id="userStats"></div>
          <h6 class="fw-bold mb-2"><i class="fa-solid fa-clock-rotate-left text-accent me-2"></i><%= t('hist.title') %></h6>
          <div class="table-responsive" id="userHistoryWrap">
            <table class="table table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th><%= t('hist.match') %></th>
                  <th class="text-center"><%= t('hist.yourPick') %></th>
                  <th class="text-center"><%= t('hist.result') %></th>
                  <th class="text-end"><%= t('hist.points') %></th>
                </tr>
              </thead>
              <tbody id="userHistory"></tbody>
            </table>
          </div>
          <div id="userHistoryEmpty" class="text-center text-secondary py-3 d-none"><%= t('hist.none') %></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // ---- User profile modal ----
  (function () {
    const LBL = {
      points: <%- JSON.stringify(t('stat.totalPoints')) %>,
      exact: <%- JSON.stringify(t('stat.exact')) %>,
      difference: <%- JSON.stringify(t('stat.difference')) %>,
      outcomes: <%- JSON.stringify(t('stat.outcomes')) %>,
      hitRate: <%- JSON.stringify(t('stat.hitRate')) %>,
      made: <%- JSON.stringify(t('stat.made')) %>,
      scored: <%- JSON.stringify(t('stat.scored')) %>,
      pending: <%- JSON.stringify(t('stat.pending')) %>,
      missed: <%- JSON.stringify(t('stat.missed')) %>,
    };
    const modalEl = document.getElementById("userModal");
    const title = document.getElementById("userModalTitle");
    const loading = document.getElementById("userLoading");
    const content = document.getElementById("userContent");
    const statsEl = document.getElementById("userStats");
    const histEl = document.getElementById("userHistory");
    const histWrap = document.getElementById("userHistoryWrap");
    const histEmpty = document.getElementById("userHistoryEmpty");

    function esc(s) {
      return String(s == null ? "" : s).replace(/[&<>"]/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
    }
    function tile(label, value, cls) {
      return '<div class="col-6 col-md-3"><div class="stat-tile text-center p-2 rounded">' +
        '<div class="fw-bold fs-5 ' + (cls || "text-accent") + '">' + value + '</div>' +
        '<div class="small text-secondary">' + esc(label) + '</div></div></div>';
    }
    function ptsBadge(p) {
      if (p === 4) return '<span class="badge text-bg-success">+4</span>';
      if (p === 2) return '<span class="badge text-bg-primary">+2</span>';
      if (p === 1) return '<span class="badge text-bg-info">+1</span>';
      if (p === 0) return '<span class="badge text-bg-secondary">0</span>';
      return '<span class="text-secondary">—</span>';
    }

    document.querySelectorAll(".user-row, .podium-place").forEach(function (row) {
      row.addEventListener("click", function () {
        const id = row.dataset.id;
        loading.classList.remove("d-none");
        content.classList.add("d-none");
        statsEl.innerHTML = "";
        histEl.innerHTML = "";
        title.innerHTML = "…";
        bootstrap.Modal.getOrCreateInstance(modalEl).show();

        fetch("/leaderboard/user/" + id)
          .then((r) => r.json())
          .then(function (d) {
            if (d.error) throw new Error(d.error);
            const av = d.avatar
              ? '<img src="' + esc(d.avatar) + '" class="avatar-mini" alt="" />'
              : '<i class="fa-solid fa-user-circle text-secondary"></i>';
            title.innerHTML = av + " " + esc(d.username);

            const s = d.stats;
            statsEl.innerHTML =
              tile(LBL.points, s.totalPoints, "text-accent") +
              tile(LBL.exact, s.exact, "text-success") +
              tile(LBL.difference, s.difference, "text-primary") +
              tile(LBL.outcomes, s.outcome, "text-info") +
              tile(LBL.hitRate, s.hitRate + "%", "text-accent") +
              tile(LBL.made, s.made) +
              tile(LBL.scored, s.scored) +
              tile(LBL.pending, s.pending) +
              tile(LBL.missed, s.missed, "text-danger");

            if (!d.history.length) {
              histWrap.classList.add("d-none");
              histEmpty.classList.remove("d-none");
            } else {
              histWrap.classList.remove("d-none");
              histEmpty.classList.add("d-none");
              histEl.innerHTML = d.history.map(function (h) {
                return "<tr><td>" + esc(h.teamA) + ' <span class="text-secondary">vs</span> ' + esc(h.teamB) + "</td>" +
                  '<td class="text-center fw-semibold">' + esc(h.pred) + "</td>" +
                  '<td class="text-center">' + esc(h.result || "—") + "</td>" +
                  '<td class="text-end">' + ptsBadge(h.points) + "</td></tr>";
              }).join("");
            }

            loading.classList.add("d-none");
            content.classList.remove("d-none");
          })
          .catch(function () {
            loading.innerHTML = '<span class="text-danger">Failed to load.</span>';
          });
      });
    });
  })();
</script>

<script>
  // Client-side search filter.
  const input = document.getElementById("searchInput");
  const rows = Array.from(document.querySelectorAll("#leaderboardBody tr"));
  const noResults = document.getElementById("noResults");
  input.addEventListener("input", function () {
    const q = this.value.trim().toLowerCase();
    let visible = 0;
    rows.forEach((r) => {
      const match = r.dataset.name.includes(q);
      r.style.display = match ? "" : "none";
      if (match) visible++;
    });
    noResults.classList.toggle("d-none", visible !== 0);
  });
</script>

<%- include("partials/footer") %>
