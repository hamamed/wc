<%- include("partials/head", { title: "Admin · WC 2026 Predictor" }) %>
<%- include("partials/navbar") %>

<%
  function fmtDate(d) {
    return d.toLocaleString("en-GB", {
      timeZone: "Etc/GMT-1",            // fixed GMT+1
      weekday: "short", month: "short", day: "numeric",
      hour: "2-digit", minute: "2-digit", hour12: false
    });
  }
  const EMOJIS = ["⚽","🏆","🥇","🔥","🎉","📣","🎯","⭐","✅","❌","👍","👎","❤️","⚡","😀","🤔","🇲🇦","🇫🇷","🇧🇷","🇦🇷"];
  function emojiBar(targetId) {
    return '<div class="emoji-toolbar" data-target="' + targetId + '">' +
      EMOJIS.map(function (e) { return '<button type="button" class="emoji-btn">' + e + '</button>'; }).join("") +
      '</div>';
  }
%>

<div class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
      <h2 class="fw-bold mb-0"><i class="fa-solid fa-screwdriver-wrench text-accent me-2"></i>Admin Panel</h2>
      <p class="text-secondary mb-0">Enter final scores to auto-score every prediction.</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/admin/users" class="btn btn-accent btn-sm fw-semibold">
        <i class="fa-solid fa-users me-1"></i> Manage Users
      </a>
      <a href="/admin/logout" class="btn btn-outline-secondary btn-sm">
        <i class="fa-solid fa-right-from-bracket me-1"></i> Exit admin
      </a>
    </div>
  </div>

  <!-- Action launcher: each tool opens in its own modal -->
  <div class="row g-2 mb-4">
    <div class="col-6 col-md-4 col-lg-2">
      <button type="button" class="btn admin-tile w-100 h-100" data-bs-toggle="modal" data-bs-target="#matchModal">
        <i class="fa-solid fa-plus"></i><span>Add a match</span>
      </button>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
      <button type="button" class="btn admin-tile w-100 h-100" data-bs-toggle="modal" data-bs-target="#predModal">
        <i class="fa-solid fa-pen"></i><span>Add / edit prediction</span>
      </button>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
      <button type="button" class="btn admin-tile w-100 h-100" data-bs-toggle="modal" data-bs-target="#pollModal">
        <i class="fa-solid fa-square-poll-vertical"></i><span>Feature polls</span>
      </button>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
      <button type="button" class="btn admin-tile w-100 h-100" data-bs-toggle="modal" data-bs-target="#annModal">
        <i class="fa-solid fa-bullhorn"></i><span>Announcements</span>
      </button>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
      <button type="button" class="btn admin-tile w-100 h-100" data-bs-toggle="modal" data-bs-target="#championModal">
        <i class="fa-solid fa-crown"></i><span>Set Champion</span>
      </button>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
      <button type="button" class="btn admin-tile w-100 h-100" data-bs-toggle="modal" data-bs-target="#importModal">
        <i class="fa-solid fa-cloud-arrow-down"></i><span>Import fixtures</span>
      </button>
    </div>
  </div>

  <!-- ===== Add a match ===== -->
  <div class="modal fade" id="matchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fa-solid fa-plus text-accent me-2"></i>Add a match manually</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <form action="/admin/match" method="POST" class="row g-2 align-items-end">
            <div class="col-12 col-md-3">
              <label class="form-label small text-secondary">Team A</label>
              <input name="teamA" class="form-control" placeholder="e.g. Brazil" required />
            </div>
            <div class="col-12 col-md-3">
              <label class="form-label small text-secondary">Team B</label>
              <input name="teamB" class="form-control" placeholder="e.g. Argentina" required />
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label small text-secondary">Kickoff time</label>
              <input name="kickoffTime" type="datetime-local" class="form-control" required />
            </div>
            <div class="col-12 col-md-2 d-grid">
              <button class="btn btn-accent fw-semibold">Add</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== Add / edit a prediction ===== -->
  <div class="modal fade" id="predModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fa-solid fa-pen text-accent me-2"></i>Add / edit a prediction</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="text-secondary small mb-3">Enter a prediction on a user's behalf. Leave Points blank to auto-score from the result.</p>
          <form action="/admin/prediction" method="POST" class="row g-2 align-items-end">
            <div class="col-12 col-md-3">
              <label class="form-label small text-secondary">User</label>
              <select name="userId" class="form-select" required>
                <option value="">— select —</option>
                <% users.forEach(function (u) { %><option value="<%= u.id %>"><%= u.username %></option><% }); %>
              </select>
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label small text-secondary">Match</label>
              <select name="matchId" class="form-select" required>
                <option value="">— select —</option>
                <% matches.forEach(function (m) { %><option value="<%= m.id %>"><%= m.teamA %> vs <%= m.teamB %></option><% }); %>
              </select>
            </div>
            <div class="col-4 col-md-1">
              <label class="form-label small text-secondary">A</label>
              <input name="scoreA" type="number" min="0" max="99" class="form-control text-center" placeholder="0" required />
            </div>
            <div class="col-4 col-md-1">
              <label class="form-label small text-secondary">B</label>
              <input name="scoreB" type="number" min="0" max="99" class="form-control text-center" placeholder="0" required />
            </div>
            <div class="col-4 col-md-1">
              <label class="form-label small text-secondary">Pts</label>
              <input name="points" type="number" min="0" max="10" class="form-control text-center" placeholder="auto" />
            </div>
            <div class="col-12 col-md-2 d-grid">
              <button class="btn btn-accent fw-semibold">Save</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== Feature polls ===== -->
  <div class="modal fade" id="pollModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fa-solid fa-square-poll-vertical text-accent me-2"></i>Feature polls</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="text-secondary small mb-3">Ask users a Yes/No question (e.g. "Add private leagues?"). Active polls show on their dashboard.</p>
          <form action="/admin/poll" method="POST" class="mb-3">
            <%- emojiBar("pollQ") %>
            <textarea id="pollQ" name="question" class="form-control emoji-input" rows="3" maxlength="500" placeholder="e.g. Should we change scoring?  (emojis + line breaks OK)" required dir="auto"></textarea>
            <div class="d-grid d-md-block mt-2">
              <button class="btn btn-accent fw-semibold">Create poll</button>
            </div>
          </form>
          <% if (polls.length) { %>
            <ul class="list-unstyled mb-0">
              <% polls.forEach(function (p) { %>
                <li class="py-2 border-top">
                  <div class="d-flex align-items-center gap-2">
                    <span class="badge wc-badge <%= p.active ? 'badge-open' : 'badge-locked' %>"><%= p.active ? 'Active' : 'Closed' %></span>
                    <span class="flex-grow-1 small pre-line" dir="auto"><%= p.question %></span>
                    <span class="small text-success fw-bold">✓ <%= p.yes %></span>
                    <span class="small text-danger fw-bold">✗ <%= p.no %></span>
                    <% if (p.voters.length) { %>
                      <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#voters-<%= p.id %>" title="Show voters"><i class="fa-solid fa-users"></i></button>
                    <% } %>
                    <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#editPoll-<%= p.id %>" title="Edit question"><i class="fa-solid fa-pen"></i></button>
                    <form action="/admin/poll/<%= p.id %>/toggle" method="POST"><button class="btn btn-outline-secondary btn-sm" title="Open/close"><i class="fa-solid fa-power-off"></i></button></form>
                    <form action="/admin/poll/<%= p.id %>/delete" method="POST" onsubmit="return confirm('Delete this poll and its votes?');"><button class="btn btn-outline-danger btn-sm"><i class="fa-solid fa-trash"></i></button></form>
                  </div>
                  <div class="collapse mt-2" id="editPoll-<%= p.id %>">
                    <form action="/admin/poll/<%= p.id %>/edit" method="POST">
                      <%- emojiBar("editPollQ-" + p.id) %>
                      <textarea id="editPollQ-<%= p.id %>" name="question" class="form-control emoji-input" rows="3" maxlength="500" required dir="auto"><%= p.question %></textarea>
                      <div class="d-flex gap-2 mt-2">
                        <button class="btn btn-accent btn-sm fw-semibold">Save changes</button>
                        <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#editPoll-<%= p.id %>">Cancel</button>
                      </div>
                    </form>
                  </div>
                  <% if (p.voters.length) { %>
                    <div class="collapse mt-2" id="voters-<%= p.id %>">
                      <div class="d-flex flex-wrap gap-2">
                        <% p.voters.forEach(function (v) { %>
                          <span class="badge rounded-pill <%= v.choice ? 'text-bg-success' : 'text-bg-danger' %>">
                            <i class="fa-solid <%= v.choice ? 'fa-check' : 'fa-xmark' %> me-1"></i><%= v.username %>
                          </span>
                        <% }); %>
                      </div>
                    </div>
                  <% } %>
                </li>
              <% }); %>
            </ul>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== Announcements ===== -->
  <div class="modal fade" id="annModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fa-solid fa-bullhorn text-accent me-2"></i>Announcements</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="text-secondary small mb-3">Active announcements show as a banner on every user's dashboard.</p>
          <form action="/admin/announcement" method="POST" class="mb-3">
            <%- emojiBar("annMsg") %>
            <textarea id="annMsg" name="message" class="form-control emoji-input" rows="3" maxlength="500" placeholder="Write an announcement…  (emojis + line breaks OK)" required dir="auto"></textarea>
            <div class="d-grid d-md-block mt-2">
              <button class="btn btn-accent fw-semibold">Post</button>
            </div>
          </form>
          <% if (announcements.length) { %>
            <ul class="list-unstyled mb-0">
              <% announcements.forEach(function (a) { %>
                <li class="d-flex align-items-start gap-2 py-2 border-top">
                  <span class="badge wc-badge <%= a.active ? 'badge-open' : 'badge-locked' %>"><%= a.active ? 'Active' : 'Hidden' %></span>
                  <span class="flex-grow-1 small pre-line" dir="auto"><%= a.message %></span>
                  <form action="/admin/announcement/<%= a.id %>/toggle" method="POST"><button class="btn btn-outline-secondary btn-sm" title="Show/hide"><i class="fa-solid fa-eye"></i></button></form>
                  <form action="/admin/announcement/<%= a.id %>/delete" method="POST" onsubmit="return confirm('Delete this announcement?');"><button class="btn btn-outline-danger btn-sm"><i class="fa-solid fa-trash"></i></button></form>
                </li>
              <% }); %>
            </ul>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== Set the World Cup champion ===== -->
  <div class="modal fade" id="championModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fa-solid fa-crown text-accent me-2"></i>Set the World Cup Champion</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="text-secondary small mb-3">
            Awards <strong>+<%= championBonus %></strong> points to every user who predicted this team.
            <% if (actualChampion) { %>Current: <strong><%= actualChampion %></strong>.<% } %>
          </p>
          <form action="/admin/champion" method="POST" class="row g-2 align-items-center"
                onsubmit="return confirm('Set champion and award the bonus to correct predictions?');">
            <div class="col-12 col-md">
              <select name="champion" class="form-select">
                <option value="">— Not decided yet —</option>
                <% teams.forEach(function (t) { %>
                  <option value="<%= t.name %>" <%= actualChampion === t.name ? 'selected' : '' %>><%= t.name %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-12 col-md-auto d-grid">
              <button class="btn btn-accent fw-semibold"><i class="fa-solid fa-crown me-1"></i> Save Champion</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== Import fixtures ===== -->
  <div class="modal fade" id="importModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fa-solid fa-cloud-arrow-down text-accent me-2"></i>Import World Cup fixtures</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="text-secondary small mb-3">
            Pulls matches &amp; flags from the football API. Finished matches are auto-scored.
          </p>
          <form action="/admin/import" method="POST" class="d-grid">
            <button class="btn btn-accent fw-semibold">
              <i class="fa-solid fa-rotate me-1"></i> Import / Refresh
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Bulk actions bar -->
  <div class="d-flex align-items-center gap-2 mb-2">
    <span id="selCount" class="text-secondary small">0 selected</span>
    <button id="deleteSelectedBtn" class="btn btn-outline-danger btn-sm ms-auto" disabled>
      <i class="fa-solid fa-trash me-1"></i> Delete selected
    </button>
  </div>
  <!-- Hidden form used to submit the checked match IDs -->
  <form id="bulkForm" action="/admin/delete-selected" method="POST" class="d-none"></form>

  <!-- Matches list with result entry -->
  <div class="card wc-card border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th class="ps-3" style="width:38px;">
              <input type="checkbox" id="selectAll" class="form-check-input" title="Select all" />
            </th>
            <th>Match</th>
            <th>Kickoff</th>
            <th>Status</th>
            <th class="text-end">Final Score</th>
            <th class="text-end pe-4">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (matches.length === 0) { %>
            <tr><td colspan="6" class="text-center text-secondary py-4">No matches yet.</td></tr>
          <% } %>
          <% matches.forEach(function (m) { %>
            <tr>
              <td class="ps-3">
                <input type="checkbox" class="form-check-input row-check" value="<%= m.id %>" />
              </td>
              <td class="fw-semibold">
                <% if (m.flagA) { %><img src="<%= m.flagA %>" class="flag-mini" alt="" /><% } %>
                <%= m.teamA %>
                <span class="text-secondary">vs</span>
                <% if (m.flagB) { %><img src="<%= m.flagB %>" class="flag-mini" alt="" /><% } %>
                <%= m.teamB %>
              </td>
              <td class="text-secondary small"><%= fmtDate(m.kickoffTime) %></td>
              <td>
                <% if (m.status === "completed") { %>
                  <span class="badge wc-badge badge-done">Completed</span>
                <% } else { %>
                  <span class="badge wc-badge badge-open">Scheduled</span>
                <% } %>
              </td>
              <td class="text-end">
                <% if (m.status === "completed") { %>
                  <!-- Completed: result is editable. Re-submitting re-scores every prediction. -->
                  <form action="/admin/result/<%= m.id %>" method="POST"
                        class="d-flex align-items-center justify-content-end gap-2 flex-wrap"
                        onsubmit="return confirm('Update this final result? It re-scores all predictions for this match.');">
                    <input type="number" name="actualScoreA" min="0" max="99"
                           class="form-control score-input text-center"
                           value="<%= m.actualScoreA %>" required />
                    <span class="fw-bold text-secondary">-</span>
                    <input type="number" name="actualScoreB" min="0" max="99"
                           class="form-control score-input text-center"
                           value="<%= m.actualScoreB %>" required />
                    <button class="btn btn-outline-warning btn-sm fw-semibold" title="Edit & re-score this result">
                      <i class="fa-solid fa-pen-to-square"></i> Update
                    </button>
                  </form>
                <% } else { %>
                  <!-- Shared inputs; "Live" updates the on-air score, "Final" locks + scores -->
                  <form method="POST" class="d-flex align-items-center justify-content-end gap-2 flex-wrap"
                        onsubmit="return this.__final ? confirm('Finalize this result? It scores all predictions for this match.') : true;">
                    <input type="number" name="actualScoreA" min="0" max="99"
                           class="form-control score-input text-center"
                           value="<%= m.liveScoreA != null ? m.liveScoreA : '' %>" placeholder="0" required />
                    <span class="fw-bold text-secondary">-</span>
                    <input type="number" name="actualScoreB" min="0" max="99"
                           class="form-control score-input text-center"
                           value="<%= m.liveScoreB != null ? m.liveScoreB : '' %>" placeholder="0" required />
                    <button class="btn btn-outline-danger btn-sm fw-semibold"
                            formaction="/admin/live/<%= m.id %>" title="Update live score">
                      <span class="live-dot"></span> Live
                    </button>
                    <button class="btn btn-accent btn-sm fw-semibold"
                            formaction="/admin/result/<%= m.id %>"
                            onclick="this.form.__final=true;" title="Finalize result">
                      <i class="fa-solid fa-check"></i> Final
                    </button>
                  </form>
                <% } %>
              </td>
              <td class="text-end pe-4">
                <form action="/admin/delete/<%= m.id %>" method="POST"
                      onsubmit="return confirm('Delete this match? This also removes all predictions for it and reverses any points awarded.');">
                  <button class="btn btn-outline-danger btn-sm" title="Delete match">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  (function () {
    const selectAll = document.getElementById("selectAll");
    const checks = Array.from(document.querySelectorAll(".row-check"));
    const btn = document.getElementById("deleteSelectedBtn");
    const countEl = document.getElementById("selCount");
    const form = document.getElementById("bulkForm");
    if (!btn) return;

    function checked() {
      return checks.filter((c) => c.checked);
    }
    function refresh() {
      const n = checked().length;
      countEl.textContent = n + " selected";
      btn.disabled = n === 0;
      if (selectAll) selectAll.checked = n > 0 && n === checks.length;
    }

    checks.forEach((c) => c.addEventListener("change", refresh));
    if (selectAll) {
      selectAll.addEventListener("change", function () {
        checks.forEach((c) => (c.checked = this.checked));
        refresh();
      });
    }

    btn.addEventListener("click", function () {
      const sel = checked();
      if (sel.length === 0) return;
      if (!confirm("Delete " + sel.length + " match(es)? This removes their predictions and reverses any points awarded.")) return;
      // Build hidden inputs (matchIds) and submit the hidden form.
      form.innerHTML = "";
      sel.forEach((c) => {
        const input = document.createElement("input");
        input.type = "hidden";
        input.name = "matchIds";
        input.value = c.value;
        form.appendChild(input);
      });
      form.submit();
    });

    refresh();
  })();

  // Emoji editor — insert the clicked emoji at the cursor in the target textarea.
  document.querySelectorAll(".emoji-toolbar .emoji-btn").forEach(function (b) {
    b.addEventListener("click", function () {
      const ta = document.getElementById(b.closest(".emoji-toolbar").dataset.target);
      if (!ta) return;
      const s = ta.selectionStart, e = ta.selectionEnd, em = b.textContent;
      ta.value = ta.value.slice(0, s) + em + ta.value.slice(e);
      ta.focus();
      const pos = s + em.length;
      ta.setSelectionRange(pos, pos);
    });
  });
</script>

<%- include("partials/footer") %>
