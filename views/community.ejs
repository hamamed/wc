<%- include("partials/head", { title: "Community · WC 2026 Predictor" }) %>
<%- include("partials/navbar") %>

<%
  function ago(d) {
    const s = Math.floor((Date.now() - new Date(d).getTime()) / 1000);
    if (s < 60) return s + "s";
    if (s < 3600) return Math.floor(s / 60) + "m";
    if (s < 86400) return Math.floor(s / 3600) + "h";
    return Math.floor(s / 86400) + "d";
  }
%>

<div class="container py-4" style="max-width:760px;">
  <div class="mb-4">
    <h2 class="fw-bold mb-0"><i class="fa-solid fa-comments text-accent me-2"></i><%= t('comm2.title') %></h2>
    <p class="text-secondary mb-0"><%= t('comm2.subtitle') %></p>
  </div>

  <!-- New post -->
  <div class="card wc-card border-0 mb-4">
    <div class="card-body">
      <form action="/community/post" method="POST">
        <textarea name="body" class="form-control mb-2" rows="3" maxlength="2000" dir="auto"
                  placeholder="<%= t('comm2.placeholder') %>" required></textarea>
        <div class="d-grid d-sm-block">
          <button class="btn btn-accent fw-semibold"><i class="fa-solid fa-paper-plane me-1"></i><%= t('comm2.post') %></button>
        </div>
      </form>
    </div>
  </div>

  <!-- Sort tabs -->
  <div class="btn-group btn-group-sm mb-3" role="group">
    <a href="/community?sort=top" class="btn <%= sort === 'top' ? 'btn-accent' : 'btn-outline-secondary' %>"><i class="fa-solid fa-fire me-1"></i><%= t('comm2.top') %></a>
    <a href="/community?sort=new" class="btn <%= sort === 'new' ? 'btn-accent' : 'btn-outline-secondary' %>"><i class="fa-solid fa-clock me-1"></i><%= t('comm2.new') %></a>
  </div>

  <% if (!posts.length) { %>
    <div class="text-center text-secondary py-5"><i class="fa-solid fa-comment-dots fa-2x mb-3 d-block"></i><%= t('comm2.empty') %></div>
  <% } %>

  <% posts.forEach(function (p) { %>
    <div class="card wc-card border-0 mb-3 <%= p.isNew ? 'post-new' : (p.hasNewComments ? 'post-newc' : '') %>" id="post-<%= p.id %>">
      <div class="card-body d-flex gap-3">
        <!-- Vote column -->
        <div class="vote-col text-center" data-id="<%= p.id %>">
          <button class="vote-btn up <%= p.myVote === 1 ? 'active' : '' %>" data-value="1" title="Upvote"><i class="fa-solid fa-caret-up"></i></button>
          <div class="vote-score fw-bold"><%= p.score %></div>
          <button class="vote-btn down <%= p.myVote === -1 ? 'active' : '' %>" data-value="-1" title="Downvote"><i class="fa-solid fa-caret-down"></i></button>
        </div>
        <!-- Body -->
        <div class="flex-grow-1 min-w-0">
          <div class="small text-secondary mb-1">
            <% if (p.avatar) { %><img src="<%= avatarSrc(p.avatar) %>" class="avatar-mini me-1" alt="" /><% } else { %><i class="fa-solid fa-user-circle me-1"></i><% } %>
            <span class="fw-semibold text-body"><%= p.username %></span> · <%= ago(p.createdAt) %>
            <% if (p.isNew) { %><span class="badge rounded-pill text-bg-danger ms-1"><%= t('comm2.new') %></span><% } else if (p.hasNewComments) { %><span class="badge rounded-pill text-bg-primary ms-1"><i class="fa-solid fa-comment-dots me-1"></i><%= t('comm2.new') %></span><% } %>
            <% if (isAdmin && p.reportCount > 0) { %><span class="badge rounded-pill text-bg-warning ms-1"><i class="fa-solid fa-flag me-1"></i><%= p.reportCount %> <%= t('comm2.flagged') %></span><% } %>
            <% if (p.username === currentUser.username || isAdmin) { %>
              <button class="btn btn-link btn-sm text-secondary p-0 ms-1 edit-toggle" type="button" data-id="<%= p.id %>" title="<%= t('comm2.editL') %>"><i class="fa-solid fa-pen"></i></button>
              <form action="/community/post/<%= p.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this post?');">
                <button class="btn btn-link btn-sm text-danger p-0 ms-1" title="Delete"><i class="fa-solid fa-trash"></i></button>
              </form>
            <% } %>
            <% if (p.username !== currentUser.username) { %>
              <button class="btn btn-link btn-sm text-secondary p-0 ms-1 report-btn" type="button" data-id="<%= p.id %>" <%= p.myReport ? 'disabled' : '' %> title="<%= t('comm2.report') %>">
                <i class="fa-solid fa-flag"></i> <%= p.myReport ? t('comm2.reported') : '' %>
              </button>
            <% } %>
          </div>
          <div class="pre-line mb-2 post-body" dir="auto"><%= p.body %></div>
          <% if (p.username === currentUser.username || isAdmin) { %>
            <form action="/community/post/<%= p.id %>/edit" method="POST" class="collapse mb-2" id="edit-<%= p.id %>">
              <textarea name="body" class="form-control mb-2" rows="3" maxlength="2000" dir="auto"><%= p.body %></textarea>
              <button class="btn btn-accent btn-sm fw-semibold"><%= t('comm2.save') %></button>
            </form>
          <% } %>

          <!-- Reactions -->
          <div class="reaction-bar mb-2" data-id="<%= p.id %>">
            <% reactionSet.forEach(function (em) {
                 const r = (p.reactions || []).find(function (x) { return x.emoji === em; });
                 const count = r ? r.count : 0; const mine = r && r.mine; %>
              <button type="button" class="reaction-btn <%= mine ? 'active' : '' %>" data-emoji="<%= em %>"><%= em %><span class="rc"><%= count > 0 ? count : '' %></span></button>
            <% }); %>
          </div>

          <button class="btn btn-link btn-sm p-0 text-secondary text-decoration-none" type="button" data-bs-toggle="collapse" data-bs-target="#c-<%= p.id %>">
            <i class="fa-regular fa-comment me-1"></i><%= p.commentCount %> <%= t('comm2.comments') %>
          </button>

          <div class="collapse mt-2" id="c-<%= p.id %>">
            <%
              const replies = {};
              p.comments.forEach(function (c) { if (c.parentId) { (replies[c.parentId] = replies[c.parentId] || []).push(c); } });
              function commentRow(c, isReply) { %>
                <div class="d-flex gap-2 py-2 border-top <%= c.isNew ? 'comment-new' : '' %> <%= isReply ? 'ms-4' : '' %>">
                  <div class="flex-grow-1 min-w-0">
                    <div class="small text-secondary">
                      <% if (c.avatar) { %><img src="<%= avatarSrc(c.avatar) %>" class="avatar-mini me-1" alt="" /><% } %>
                      <span class="fw-semibold text-body"><%= c.username %></span> · <%= ago(c.createdAt) %>
                    </div>
                    <div class="pre-line small" dir="auto"><%= c.body %></div>
                    <% if (!isReply) { %>
                      <button class="btn btn-link btn-sm p-0 text-secondary text-decoration-none reply-toggle" type="button" data-id="<%= c.id %>"><i class="fa-solid fa-reply me-1"></i><%= t('comm2.reply') %></button>
                      <form action="/community/post/<%= p.id %>/comment" method="POST" class="collapse mt-1 d-flex gap-2" id="reply-<%= c.id %>">
                        <input type="hidden" name="parentId" value="<%= c.id %>" />
                        <input name="body" class="form-control form-control-sm" maxlength="1000" dir="auto" placeholder="<%= t('comm2.addComment') %>" required />
                        <button class="btn btn-accent btn-sm"><i class="fa-solid fa-paper-plane"></i></button>
                      </form>
                    <% } %>
                  </div>
                  <% if (c.username === currentUser.username || isAdmin) { %>
                    <form action="/community/comment/<%= c.id %>/delete" method="POST" onsubmit="return confirm('Delete this comment?');">
                      <button class="btn btn-link btn-sm text-danger p-0" title="Delete"><i class="fa-solid fa-trash"></i></button>
                    </form>
                  <% } %>
                </div>
            <% }
              p.comments.filter(function (c) { return !c.parentId; }).forEach(function (c) {
                commentRow(c, false);
                (replies[c.id] || []).forEach(function (r) { commentRow(r, true); });
              });
            %>
            <form action="/community/post/<%= p.id %>/comment" method="POST" class="d-flex gap-2 mt-2">
              <input name="body" class="form-control form-control-sm" maxlength="1000" dir="auto" placeholder="<%= t('comm2.addComment') %>" required />
              <button class="btn btn-accent btn-sm fw-semibold"><i class="fa-solid fa-paper-plane"></i></button>
            </form>
          </div>
        </div>
      </div>
    </div>
  <% }); %>
</div>

<script>
  // Edit toggle (reveal the inline edit form).
  document.querySelectorAll(".edit-toggle").forEach(function (b) {
    b.addEventListener("click", function () {
      var f = document.getElementById("edit-" + b.dataset.id);
      if (f) f.classList.toggle("show");
    });
  });
  // Report a post.
  document.querySelectorAll(".report-btn").forEach(function (b) {
    b.addEventListener("click", function () {
      if (b.disabled) return;
      if (!confirm("Report this post to the admins?")) return;
      fetch("/community/post/" + b.dataset.id + "/report", { method: "POST" })
        .then(function (r) { return r.json(); })
        .then(function (j) { if (j.ok) { b.disabled = true; b.innerHTML = '<i class="fa-solid fa-flag"></i> Reported'; } })
        .catch(function () {});
    });
  });

  // Reply toggles.
  document.querySelectorAll(".reply-toggle").forEach(function (b) {
    b.addEventListener("click", function () {
      var f = document.getElementById("reply-" + b.dataset.id);
      if (f) f.classList.toggle("show");
    });
  });
  // Emoji reactions.
  document.querySelectorAll(".reaction-bar").forEach(function (bar) {
    var id = bar.dataset.id;
    bar.querySelectorAll(".reaction-btn").forEach(function (btn) {
      btn.addEventListener("click", function () {
        fetch("/community/post/" + id + "/react", {
          method: "POST", headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ emoji: btn.dataset.emoji }),
        }).then(function (r) { return r.json(); }).then(function (j) {
          if (!j.ok) return;
          bar.querySelectorAll(".reaction-btn").forEach(function (b2) {
            var r = j.reactions.find(function (x) { return x.emoji === b2.dataset.emoji; });
            b2.classList.toggle("active", !!(r && r.mine));
            b2.querySelector(".rc").textContent = r && r.count > 0 ? r.count : "";
          });
        }).catch(function () {});
      });
    });
  });

  // AJAX up/down voting.
  document.querySelectorAll(".vote-col").forEach(function (col) {
    const id = col.dataset.id;
    const scoreEl = col.querySelector(".vote-score");
    col.querySelectorAll(".vote-btn").forEach(function (btn) {
      btn.addEventListener("click", function () {
        const wanted = parseInt(btn.dataset.value, 10);
        const already = btn.classList.contains("active");
        const value = already ? 0 : wanted;
        fetch("/community/post/" + id + "/vote", {
          method: "POST", headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ value: value }),
        }).then((r) => r.json()).then(function (j) {
          if (!j.ok) return;
          scoreEl.textContent = j.score;
          col.querySelectorAll(".vote-btn").forEach((b) => b.classList.remove("active"));
          if (value !== 0) btn.classList.add("active");
        }).catch(function () {});
      });
    });
  });
</script>

<%- include("partials/footer") %>
