<%- include("partials/head", { title: "My Stats · WC 2026 Predictor" }) %>
<%- include("partials/navbar") %>

<%
  function fmtDate(d) {
    return d.toLocaleString("en-US", {
      month: "short", day: "numeric", hour: "numeric", minute: "2-digit"
    });
  }
%>

<div class="container py-4">
  <div class="d-flex flex-wrap align-items-center gap-3 mb-4">
    <div class="profile-avatar"><i class="fa-solid fa-user-astronaut"></i></div>
    <div>
      <h2 class="fw-bold mb-0"><%= currentUser.username %></h2>
      <p class="text-secondary mb-0">Your predictions &amp; points summary</p>
    </div>
  </div>

  <!-- Points summary cards -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
      <div class="card wc-card stat-card border-0 h-100">
        <div class="card-body">
          <div class="stat-icon"><i class="fa-solid fa-star"></i></div>
          <div class="stat-value text-accent"><%= stats.totalPoints %></div>
          <div class="stat-label">Total Points</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card wc-card stat-card border-0 h-100">
        <div class="card-body">
          <div class="stat-icon"><i class="fa-solid fa-bullseye"></i></div>
          <div class="stat-value text-gold"><%= stats.exact %></div>
          <div class="stat-label">Exact Scores <span class="text-secondary">(2 pts)</span></div>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card wc-card stat-card border-0 h-100">
        <div class="card-body">
          <div class="stat-icon"><i class="fa-solid fa-check-double"></i></div>
          <div class="stat-value"><%= stats.outcome %></div>
          <div class="stat-label">Correct Outcomes <span class="text-secondary">(1 pt)</span></div>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card wc-card stat-card border-0 h-100">
        <div class="card-body">
          <div class="stat-icon"><i class="fa-solid fa-percent"></i></div>
          <div class="stat-value"><%= stats.hitRate %>%</div>
          <div class="stat-label">Hit Rate <span class="text-secondary">(scored)</span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Secondary tallies -->
  <div class="d-flex flex-wrap gap-2 mb-4">
    <span class="badge wc-badge badge-open"><i class="fa-solid fa-list-check me-1"></i><%= stats.made %> Predictions made</span>
    <span class="badge wc-badge badge-done"><i class="fa-solid fa-flag-checkered me-1"></i><%= stats.scored %> Scored</span>
    <span class="badge wc-badge badge-locked"><i class="fa-solid fa-hourglass-half me-1"></i><%= stats.pending %> Pending</span>
    <span class="badge wc-badge badge-locked"><i class="fa-solid fa-xmark me-1"></i><%= stats.missed %> Missed</span>
  </div>

  <!-- Prediction history -->
  <h5 class="fw-semibold mb-3"><i class="fa-solid fa-clock-rotate-left text-accent me-2"></i>Prediction History</h5>
  <div class="card wc-card border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th class="ps-4">Match</th>
            <th>Kickoff</th>
            <th class="text-center">Your Pick</th>
            <th class="text-center">Result</th>
            <th class="text-end pe-4">Points</th>
          </tr>
        </thead>
        <tbody>
          <% if (history.length === 0) { %>
            <tr><td colspan="5" class="text-center text-secondary py-4">
              No predictions yet. <a href="/dashboard" class="text-accent">Make your first pick →</a>
            </td></tr>
          <% } %>
          <% history.forEach(function (h) { %>
            <tr>
              <td class="ps-4 fw-semibold"><%= h.teamA %> <span class="text-secondary">vs</span> <%= h.teamB %></td>
              <td class="text-secondary small"><%= fmtDate(h.kickoffTime) %></td>
              <td class="text-center fw-semibold"><%= h.predictedScoreA %>-<%= h.predictedScoreB %></td>
              <td class="text-center">
                <% if (h.status === "completed") { %>
                  <span class="text-gold fw-bold"><%= h.actualScoreA %>-<%= h.actualScoreB %></span>
                <% } else { %>
                  <span class="text-secondary">—</span>
                <% } %>
              </td>
              <td class="text-end pe-4">
                <% if (h.pointsEarned === null) { %>
                  <span class="badge wc-badge badge-locked">Pending</span>
                <% } else if (h.pointsEarned === 2) { %>
                  <span class="badge wc-badge badge-done">+2 Exact</span>
                <% } else if (h.pointsEarned === 1) { %>
                  <span class="badge wc-badge badge-open">+1 Outcome</span>
                <% } else { %>
                  <span class="badge wc-badge badge-locked">0</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include("partials/footer") %>
