<%- include("partials/head", { title: "My Stats · WC 2026 Predictor" }) %>
<%- include("partials/navbar") %>

<%
  function fmtDate(d) {
    return d.toLocaleString("en-GB", {
      timeZone: "Etc/GMT-1",            // fixed GMT+1
      month: "short", day: "numeric",
      hour: "2-digit", minute: "2-digit", hour12: false
    });
  }
%>

<div class="container py-4">
  <div class="d-flex flex-wrap align-items-center gap-3 mb-4">
    <div class="profile-avatar">
      <% if (avatar) { %>
        <img src="/avatars/<%= avatar %>" alt="avatar" />
      <% } else { %>
        <i class="fa-solid fa-user-astronaut"></i>
      <% } %>
    </div>
    <div class="me-auto">
      <h2 class="fw-bold mb-0"><%= currentUser.username %></h2>
      <p class="text-secondary mb-0"><%= t('profile.summary') %></p>
    </div>
    <div class="d-flex gap-2">
      <form action="/profile/avatar" method="POST">
        <button class="btn btn-outline-secondary btn-sm" <%= hasAvatars ? '' : 'disabled title="Add images to public/avatars/"' %>>
          <i class="fa-solid fa-shuffle me-1"></i> <%= t('profile.changePhoto') %>
        </button>
      </form>
      <a href="/logout" class="btn btn-outline-danger btn-sm">
        <i class="fa-solid fa-right-from-bracket me-1"></i> <%= t('profile.logout') %>
      </a>
    </div>
  </div>

  <!-- Champion prediction banner -->
  <div class="card wc-card border-0 mb-4 champion-banner">
    <div class="card-body">
      <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
        <h6 class="fw-bold mb-0"><i class="fa-solid fa-crown text-accent me-2"></i><%= t('champ.title') %></h6>
        <% if (championLocked) { %>
          <span class="badge wc-badge badge-locked ms-auto"><i class="fa-solid fa-lock me-1"></i> <%= t('champ.locked') %></span>
        <% } else { %>
          <span class="badge wc-badge badge-open ms-auto">
            <i class="fa-solid fa-hourglass-half me-1"></i> <%= t('champ.locksIn') %> <strong id="champCountdown">…</strong>
          </span>
        <% } %>
      </div>

      <% if (championLocked) { %>
        <p class="mb-0">
          <%= t('champ.your') %>
          <% if (championPick) { %>
            <% if (championFlag) { %><img src="<%= championFlag %>" class="flag-mini" alt="" /><% } %>
            <span class="fw-bold"><%= tn(championPick) %></span>
          <% } else { %>
            <span class="text-secondary fst-italic"><%= t('champ.noPick') %></span>
          <% } %>
        </p>
      <% } else if (teams.length === 0) { %>
        <p class="text-secondary mb-0"><%= t('champ.teamsAppear') %></p>
      <% } else { %>
        <form action="/champion" method="POST" class="row g-2 align-items-center">
          <div class="col-12 col-md">
            <select name="champion" class="form-select" required>
              <option value="" disabled <%= championPick ? '' : 'selected' %>><%= t('champ.choose') %></option>
              <% teams.forEach(function (tm) { %>
                <option value="<%= tm.name %>" <%= championPick === tm.name ? 'selected' : '' %>><%= tn(tm.name) %></option>
              <% }); %>
            </select>
          </div>
          <div class="col-12 col-md-auto d-grid">
            <button class="btn btn-accent fw-semibold"><i class="fa-solid fa-crown me-1"></i> <%= t('champ.save') %></button>
          </div>
        </form>
        <% if (championPick) { %>
          <p class="text-secondary small mt-2 mb-0">
            <%= t('champ.current') %>
            <% if (championFlag) { %><img src="<%= championFlag %>" class="flag-mini" alt="" /><% } %>
            <span class="fw-semibold"><%= championPick %></span> — <%= t('champ.canChange') %>
          </p>
        <% } %>
      <% } %>

      <!-- Result once the actual champion is set -->
      <% if (actualChampion) { %>
        <hr class="my-3" />
        <p class="mb-0">
          <%= t('champ.actual') %> <span class="fw-bold"><%= tn(actualChampion) %></span>
          <% if (championPick) { %>
            <% if (championPick === actualChampion) { %>
              <span class="badge wc-badge badge-done ms-2"><i class="fa-solid fa-circle-check me-1"></i><%= t('champ.correct') %></span>
            <% } else { %>
              <span class="badge wc-badge badge-locked ms-2"><i class="fa-solid fa-circle-xmark me-1"></i><%= t('champ.wrong') %></span>
            <% } %>
          <% } %>
        </p>
      <% } %>
    </div>
  </div>

  <!-- Points summary cards -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
      <div class="card wc-card stat-card border-0 h-100">
        <div class="card-body">
          <div class="stat-icon"><i class="fa-solid fa-star"></i></div>
          <div class="stat-value text-accent"><%= stats.totalPoints %></div>
          <div class="stat-label"><%= t('stat.totalPoints') %></div>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card wc-card stat-card border-0 h-100">
        <div class="card-body">
          <div class="stat-icon"><i class="fa-solid fa-bullseye"></i></div>
          <div class="stat-value text-gold"><%= stats.exact %></div>
          <div class="stat-label"><%= t('stat.exact') %> <span class="text-secondary"><%= t('stat.pts2') %></span></div>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card wc-card stat-card border-0 h-100">
        <div class="card-body">
          <div class="stat-icon"><i class="fa-solid fa-check-double"></i></div>
          <div class="stat-value"><%= stats.outcome %></div>
          <div class="stat-label"><%= t('stat.outcomes') %> <span class="text-secondary"><%= t('stat.pt1') %></span></div>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card wc-card stat-card border-0 h-100">
        <div class="card-body">
          <div class="stat-icon"><i class="fa-solid fa-percent"></i></div>
          <div class="stat-value"><%= stats.hitRate %>%</div>
          <div class="stat-label"><%= t('stat.hitRate') %> <span class="text-secondary"><%= t('stat.scoredParen') %></span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Secondary tallies -->
  <div class="d-flex flex-wrap gap-2 mb-4">
    <span class="badge wc-badge badge-open"><i class="fa-solid fa-list-check me-1"></i><%= stats.made %> <%= t('stat.made') %></span>
    <span class="badge wc-badge badge-done"><i class="fa-solid fa-flag-checkered me-1"></i><%= stats.scored %> <%= t('stat.scored') %></span>
    <span class="badge wc-badge badge-locked"><i class="fa-solid fa-hourglass-half me-1"></i><%= stats.pending %> <%= t('stat.pending') %></span>
    <span class="badge wc-badge badge-locked"><i class="fa-solid fa-xmark me-1"></i><%= stats.missed %> <%= t('stat.missed') %></span>
  </div>

  <!-- Prediction history -->
  <h5 class="fw-semibold mb-3"><i class="fa-solid fa-clock-rotate-left text-accent me-2"></i><%= t('hist.title') %></h5>
  <div class="card wc-card border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th class="ps-4"><%= t('hist.match') %></th>
            <th><%= t('hist.kickoff') %></th>
            <th class="text-center"><%= t('hist.yourPick') %></th>
            <th class="text-center"><%= t('hist.result') %></th>
            <th class="text-end pe-4"><%= t('hist.points') %></th>
          </tr>
        </thead>
        <tbody>
          <% if (history.length === 0) { %>
            <tr><td colspan="5" class="text-center text-secondary py-4">
              <%= t('hist.none') %> <a href="/dashboard" class="text-accent"><%= t('hist.makeFirst') %></a>
            </td></tr>
          <% } %>
          <% history.forEach(function (h) { %>
            <tr>
              <td class="ps-4 fw-semibold"><%= tn(h.teamA) %> <span class="text-secondary"><%= t('common.vs') %></span> <%= tn(h.teamB) %></td>
              <td class="text-secondary small"><%= fmtDate(h.kickoffTime) %></td>
              <td class="text-center fw-semibold"><%= h.predictedScoreA %>-<%= h.predictedScoreB %></td>
              <td class="text-center">
                <% if (h.status === "completed") { %>
                  <span class="text-gold fw-bold"><%= h.actualScoreA %>-<%= h.actualScoreB %></span>
                <% } else { %>
                  <span class="text-secondary">—</span>
                <% } %>
              </td>
              <td class="text-end pe-4">
                <% if (h.pointsEarned === null) { %>
                  <span class="badge wc-badge badge-locked"><%= t('hist.pending') %></span>
                <% } else if (h.pointsEarned === 2) { %>
                  <span class="badge wc-badge badge-done"><%= t('hist.exact') %></span>
                <% } else if (h.pointsEarned === 1) { %>
                  <span class="badge wc-badge badge-open"><%= t('hist.outcome') %></span>
                <% } else { %>
                  <span class="badge wc-badge badge-locked">0</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<% if (!championLocked) { %>
<script>
  (function () {
    const el = document.getElementById("champCountdown");
    if (!el) return;
    const lock = <%= championLockMs %>;
    function tick() {
      const ms = lock - Date.now();
      if (ms <= 0) { el.textContent = "now"; setTimeout(() => location.reload(), 1500); return; }
      const d = Math.floor(ms / 86400000);
      const h = Math.floor((ms % 86400000) / 3600000);
      const m = Math.floor((ms % 3600000) / 60000);
      const s = Math.floor((ms % 60000) / 1000);
      el.textContent = (d > 0 ? d + "d " : "") + h + "h " + m + "m " + s + "s";
    }
    tick();
    setInterval(tick, 1000);
  })();
</script>
<% } %>

<%- include("partials/footer") %>
