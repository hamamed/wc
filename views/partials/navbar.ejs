<nav class="navbar navbar-expand-lg sticky-top wc-navbar">
  <div class="container">
    <a class="navbar-brand d-flex align-items-center" href="/dashboard">
      <img src="/logo.png" alt="HAMA World Cup Predictor 2026" class="brand-logo" />
    </a>

    <!-- Language switcher (mobile: standalone in the top bar) -->
    <div class="dropdown ms-auto d-lg-none">
      <a class="nav-link dropdown-toggle lang-toggle d-flex align-items-center" href="#" role="button"
         data-bs-toggle="dropdown" aria-expanded="false">
        <i class="fa-solid fa-globe me-1"></i><%= lang.toUpperCase() %>
      </a>
      <ul class="dropdown-menu dropdown-menu-end">
        <% langs.forEach(function (l) { %>
          <li><a class="dropdown-item <%= l.code === lang ? 'active' : '' %>" href="/lang/<%= l.code %>"><%= l.label %></a></li>
        <% }); %>
      </ul>
    </div>

    <% if (currentUser) { %>
      <!-- On phones the bottom app-nav replaces the hamburger; show the user chip instead -->
      <span class="badge wc-userchip d-lg-none ms-2">
        <i class="fa-solid fa-user me-1"></i><%= currentUser.username %>
      </span>
    <% } %>

    <button
      class="navbar-toggler d-none"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navMenu"
      aria-controls="navMenu"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
        <% if (currentUser) { %>
          <li class="nav-item">
            <a class="nav-link" href="/dashboard">
              <i class="fa-solid fa-calendar-days me-1"></i> <%= t('nav.fixtures') %>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/standings">
              <i class="fa-solid fa-table-cells-large me-1"></i> <%= t('nav.groups') %>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/leaderboard">
              <i class="fa-solid fa-trophy me-1"></i> <%= t('nav.leaderboard') %>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/profile">
              <i class="fa-solid fa-user me-1"></i> <%= t('nav.profile') %>
            </a>
          </li>
          <% if (userIsAdmin) { %>
            <li class="nav-item">
              <a class="nav-link text-accent fw-semibold" href="/admin">
                <i class="fa-solid fa-screwdriver-wrench me-1"></i> Admin
              </a>
            </li>
          <% } %>
          <li class="nav-item ms-lg-2">
            <a href="/profile" class="badge wc-userchip text-decoration-none">
              <i class="fa-solid fa-user me-1"></i><%= currentUser.username %>
            </a>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/login">
              <i class="fa-solid fa-right-to-bracket me-1"></i> <%= t('nav.login') %>
            </a>
          </li>
        <% } %>
        <!-- Language switcher (desktop: inside the menu) -->
        <li class="nav-item dropdown d-none d-lg-block ms-lg-1">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="fa-solid fa-globe me-1"></i><%= lang.toUpperCase() %>
          </a>
          <ul class="dropdown-menu dropdown-menu-end">
            <% langs.forEach(function (l) { %>
              <li><a class="dropdown-item <%= l.code === lang ? 'active' : '' %>" href="/lang/<%= l.code %>"><%= l.label %></a></li>
            <% }); %>
          </ul>
        </li>
      </ul>
    </div>
  </div>
</nav>

<% if (currentUser) {
     function navActive(prefix) { return (currentPath || "").indexOf(prefix) === 0 ? "active" : ""; }
%>
<!-- Bottom app-style nav (phones/tablets only) -->
<nav class="bottom-nav d-lg-none">
  <a href="/dashboard" class="bottom-nav-item <%= navActive('/dashboard') %>">
    <i class="fa-solid fa-calendar-days"></i><span><%= t('nav.fixtures') %></span>
  </a>
  <a href="/standings" class="bottom-nav-item <%= navActive('/standings') %>">
    <i class="fa-solid fa-table-cells-large"></i><span><%= t('nav.groups') %></span>
  </a>
  <a href="/leaderboard" class="bottom-nav-item <%= navActive('/leaderboard') %>">
    <i class="fa-solid fa-trophy"></i><span><%= t('nav.ranks') %></span>
  </a>
  <a href="/profile" class="bottom-nav-item <%= navActive('/profile') %>">
    <i class="fa-solid fa-user"></i><span><%= t('nav.profile') %></span>
  </a>
  <% if (userIsAdmin) { %>
    <a href="/admin" class="bottom-nav-item <%= navActive('/admin') %>">
      <i class="fa-solid fa-screwdriver-wrench"></i><span>Admin</span>
    </a>
  <% } %>
</nav>
<% } %>

<!-- Get-the-app banner (dismissible, remembered per browser) -->
<div class="container mt-3" id="appBanner" style="display:none;">
  <div class="app-banner d-flex align-items-center gap-2">
    <i class="fa-brands fa-android fa-lg"></i>
    <span class="flex-grow-1"><%= t('app.banner') %></span>
    <a href="/download/hama.apk" download class="btn btn-accent btn-sm fw-semibold">
      <i class="fa-solid fa-download me-1"></i><%= t('app.download') %>
    </a>
    <button type="button" class="btn-close" id="appBannerClose" aria-label="Close"></button>
  </div>
</div>
<script>
  (function () {
    if (localStorage.getItem("appBannerHidden")) return;
    var b = document.getElementById("appBanner");
    if (!b) return;
    b.style.display = "";
    document.getElementById("appBannerClose").addEventListener("click", function () {
      b.style.display = "none";
      localStorage.setItem("appBannerHidden", "1");
    });
  })();
</script>

<!-- Flash messages -->
<div class="container mt-3">
  <% (success || []).forEach(function (msg) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="fa-solid fa-circle-check me-1"></i> <%= msg %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% }); %>
  <% (error || []).forEach(function (msg) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="fa-solid fa-triangle-exclamation me-1"></i> <%= msg %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% }); %>
</div>
