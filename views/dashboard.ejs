<%- include("partials/head", { title: "Fixtures · WC 2026 Predictor" }) %>
<%- include("partials/navbar") %>

<%
  function fmtDate(d) {
    return d.toLocaleString("en-GB", {
      timeZone: "Etc/GMT-1",            // fixed GMT+1
      weekday: "short", month: "short", day: "numeric",
      hour: "2-digit", minute: "2-digit", hour12: false
    });
  }
%>

<div class="container py-4">

  <!-- Announcements -->
  <% (announcements || []).forEach(function (an) { %>
    <div class="alert alert-info d-flex align-items-start gap-2 announcement" data-id="<%= an.id %>" role="alert">
      <i class="fa-solid fa-bullhorn mt-1"></i>
      <div class="flex-grow-1 pre-line" dir="auto"><%= an.message %></div>
      <button type="button" class="btn-close" aria-label="Close"></button>
    </div>
  <% }); %>

  <!-- Polls: vote on upcoming features -->
  <% if ((polls || []).length) { %>
    <div class="card wc-card border-0 mb-4">
      <div class="card-body">
        <h6 class="fw-bold mb-3"><i class="fa-solid fa-square-poll-vertical text-accent me-2"></i><%= t('comm.polls') %></h6>
        <% polls.forEach(function (p) { %>
          <div class="<%= p === polls[polls.length-1] ? '' : 'mb-4' %>">
            <div class="fw-semibold mb-2 pre-line" dir="auto"><%= p.question %></div>
            <% if (p.myVote === null || p.myVote === undefined) { %>
              <form action="/dashboard/vote/<%= p.id %>" method="POST" class="d-flex gap-2">
                <button name="choice" value="yes" class="btn btn-accent btn-sm fw-semibold"><i class="fa-solid fa-check me-1"></i><%= t('comm.yes') %></button>
                <button name="choice" value="no" class="btn btn-outline-secondary btn-sm fw-semibold"><i class="fa-solid fa-xmark me-1"></i><%= t('comm.no') %></button>
              </form>
            <% } else {
                 const total = p.yes + p.no;
                 const yp = total ? Math.round((p.yes / total) * 100) : 0;
                 const np = total ? 100 - yp : 0;
            %>
              <div class="small">
                <div class="d-flex justify-content-between"><span><%= t('comm.yes') %> · <%= p.yes %></span><span><%= yp %>%</span></div>
                <div class="progress mb-2" style="height:8px;"><div class="progress-bar bg-success" style="width:<%= yp %>%"></div></div>
                <div class="d-flex justify-content-between"><span><%= t('comm.no') %> · <%= p.no %></span><span><%= np %>%</span></div>
                <div class="progress mb-1" style="height:8px;"><div class="progress-bar bg-secondary" style="width:<%= np %>%"></div></div>
                <span class="text-secondary"><%= t('comm.youVoted') %> <strong><%= p.myVote ? t('comm.yes') : t('comm.no') %></strong> · <%= total %> <%= t('comm.votes') %></span>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>
    </div>
  <% } %>

  <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
      <h2 class="fw-bold mb-0"><i class="fa-solid fa-calendar-days text-accent me-2"></i><%= t('dash.title') %></h2>
      <p class="text-secondary mb-0"><%= t('dash.subtitle') %></p>
    </div>
    <div class="d-flex align-items-center gap-3">
      <div class="legend small text-secondary d-flex gap-3 flex-wrap">
        <span><span class="dot dot-open"></span> <%= t('dash.open') %></span>
        <span><span class="dot dot-locked"></span> <%= t('dash.locked') %></span>
        <span><span class="dot dot-done"></span> <%= t('dash.completed') %></span>
      </div>
      <button id="privacyToggle" type="button" class="btn btn-outline-secondary btn-sm" title="<%= t('dash.privacy') %>">
        <i class="fa-solid fa-eye"></i>
      </button>
    </div>
  </div>

  <!-- Day filter (chips built from the fixtures, in the visitor's timezone) -->
  <% if (matches.length > 0) { %>
    <div id="dayFilter" class="day-filter mb-4"></div>
    <div id="dayEmpty" class="text-center text-secondary py-5 d-none">
      <i class="fa-solid fa-calendar-xmark fa-2x mb-3 d-block"></i>
      <%= t('dash.noMatchesDay') %>
    </div>
  <% } %>

  <% if (matches.length === 0) { %>
    <div class="text-center text-secondary py-5">
      <i class="fa-solid fa-futbol fa-2x mb-3 d-block"></i>
      <%= t('dash.noFixtures') %>
    </div>
  <% } %>

  <div class="row g-3">
    <% matches.forEach(function (m) { %>
      <div class="col-12 col-md-6 col-xl-4 match-col" data-kickoff="<%= m.kickoffMs %>">
        <div class="card wc-card h-100 border-0 match-card match-<%= m.badge.type %>">
          <div class="card-body d-flex flex-column">

            <!-- Status badge + date -->
            <div class="d-flex justify-content-between align-items-center mb-3">
              <% if (m.badge.type === "open") { %>
                <span class="badge wc-badge badge-open">
                  <i class="fa-solid fa-unlock me-1"></i> <%= t('dash.badgeOpen') %>
                </span>
              <% } else if (m.badge.type === "live") { %>
                <span class="badge wc-badge badge-live">
                  <span class="live-dot"></span> <%= t('dash.badgeLive') %>
                </span>
              <% } else if (m.badge.type === "locked") { %>
                <span class="badge wc-badge badge-locked">
                  <i class="fa-solid fa-lock me-1"></i> <%= t('dash.locked') %>
                </span>
              <% } else { %>
                <span class="badge wc-badge badge-done">
                  <i class="fa-solid fa-flag-checkered me-1"></i>
                  <%= t('dash.completed') %><% if (m.badge.points !== null) { %> (+<%= m.badge.points %> <%= t('common.pts') %>)<% } %>
                </span>
              <% } %>
              <small class="text-secondary"><%= fmtDate(m.kickoffTime) %></small>
            </div>

            <!-- Teams -->
            <div class="d-flex align-items-center justify-content-between text-center mb-3">
              <div class="team w-100">
                <div class="team-flag">
                  <% if (m.flagA) { %>
                    <img src="<%= m.flagA %>" alt="<%= m.teamA %>" class="flag-img" />
                  <% } else { %>
                    <i class="fa-solid fa-shield-halved"></i>
                  <% } %>
                </div>
                <div class="fw-semibold mt-1"><%= tn(m.teamA) %></div>
              </div>
              <div class="vs px-2">
                <% if (m.status === "completed") { %>
                  <span class="final-score"><%= m.actualScoreA %>&nbsp;-&nbsp;<%= m.actualScoreB %></span>
                <% } else if (m.badge.type === "live") { %>
                  <span class="live-score">
                    <%= m.liveScoreA != null ? m.liveScoreA : 0 %>&nbsp;-&nbsp;<%= m.liveScoreB != null ? m.liveScoreB : 0 %>
                  </span>
                <% } else { %>
                  <span class="text-secondary fw-bold"><%= t('common.vs') %></span>
                <% } %>
              </div>
              <div class="team w-100">
                <div class="team-flag">
                  <% if (m.flagB) { %>
                    <img src="<%= m.flagB %>" alt="<%= m.teamB %>" class="flag-img" />
                  <% } else { %>
                    <i class="fa-solid fa-shield-halved"></i>
                  <% } %>
                </div>
                <div class="fw-semibold mt-1"><%= tn(m.teamB) %></div>
              </div>
            </div>

            <!-- Prediction form / state -->
            <div class="mt-auto">
              <% if (m.badge.type === "open") { %>
                <form action="/dashboard/predict/<%= m.id %>" method="POST">
                  <div class="d-flex align-items-center justify-content-center gap-2 mb-3">
                    <input type="number" name="scoreA" min="0" max="99"
                           class="form-control score-input text-center user-pred"
                           value="<%= m.prediction ? m.prediction.predictedScoreA : '' %>"
                           placeholder="0" required />
                    <span class="fw-bold text-secondary">-</span>
                    <input type="number" name="scoreB" min="0" max="99"
                           class="form-control score-input text-center user-pred"
                           value="<%= m.prediction ? m.prediction.predictedScoreB : '' %>"
                           placeholder="0" required />
                  </div>
                  <button class="btn btn-accent w-100 fw-semibold">
                    <i class="fa-solid fa-floppy-disk me-1"></i>
                    <%= m.prediction ? t('dash.update') : t('dash.save') %>
                  </button>
                </form>
                <% if (m.prediction) { %>
                  <p class="text-center text-secondary small mt-2 mb-0">
                    <i class="fa-solid fa-pen me-1"></i><%= t('dash.yourPick') %>:
                    <span class="user-pred"><%= m.prediction.predictedScoreA %>-<%= m.prediction.predictedScoreB %></span> (<%= t('dash.editable') %>)
                  </p>
                <% } %>
              <% } else { %>
                <!-- Locked or completed: show pick read-only -->
                <div class="text-center small">
                  <% if (m.prediction) { %>
                    <span class="text-secondary"><%= t('dash.yourPick') %>:</span>
                    <span class="fw-semibold user-pred">
                      <%= m.prediction.predictedScoreA %>-<%= m.prediction.predictedScoreB %>
                    </span>
                    <% if (m.status === "completed") { %>
                      <div class="mt-2">
                        <% if (m.prediction.pointsEarned === 2) { %>
                          <span class="badge wc-badge badge-done"><i class="fa-solid fa-bullseye me-1"></i><%= t('dash.exactBonus') %> <%= t('dash.earned') %> +2 <%= t('common.pts') %></span>
                        <% } else if (m.prediction.pointsEarned === 1) { %>
                          <span class="badge wc-badge badge-open"><i class="fa-solid fa-check me-1"></i><%= t('dash.earned') %> +1 <%= t('common.pts') %></span>
                        <% } else { %>
                          <span class="badge wc-badge badge-locked"><i class="fa-solid fa-xmark me-1"></i><%= t('dash.earned') %> +0 <%= t('common.pts') %></span>
                        <% } %>
                      </div>
                    <% } %>
                  <% } else { %>
                    <span class="text-secondary fst-italic">
                      <i class="fa-solid fa-ban me-1"></i><%= t('dash.noPrediction') %>
                    </span>
                  <% } %>
                  <div class="mt-2">
                    <button type="button" class="btn btn-link p-0 small text-accent text-decoration-none see-all" data-id="<%= m.id %>">
                      <i class="fa-solid fa-people-group me-1"></i><%= t('dash.seeAll') %>
                    </button>
                  </div>
                </div>
              <% } %>
            </div>

          </div>
        </div>
      </div>
    <% }); %>
  </div>

  <!-- How it works (explanation, translated) — shown under the matches -->
  <div class="card wc-card border-0 mt-4 how-card">
    <div class="card-body">
      <h6 class="fw-bold mb-3"><i class="fa-solid fa-circle-info text-accent me-2"></i><%= t('how.title') %></h6>
      <div class="row g-2 small">
        <div class="col-12 col-md-6 col-lg-4"><i class="fa-solid fa-pen text-accent me-2"></i><%= t('how.predict') %></div>
        <div class="col-12 col-md-6 col-lg-4"><i class="fa-solid fa-lock text-accent me-2"></i><%= t('how.lock') %></div>
        <div class="col-12 col-md-6 col-lg-4"><i class="fa-solid fa-bullseye text-accent me-2"></i><%= t('how.exact') %></div>
        <div class="col-12 col-md-6 col-lg-4"><i class="fa-solid fa-check-double text-accent me-2"></i><%= t('how.outcome') %></div>
        <div class="col-12 col-md-6 col-lg-4"><i class="fa-solid fa-xmark text-accent me-2"></i><%= t('how.wrong') %></div>
        <div class="col-12 col-md-6 col-lg-4"><i class="fa-solid fa-crown text-accent me-2"></i><%= t('how.champion') %></div>
      </div>
    </div>
  </div>
</div>

<script>
  // Build day-filter chips from the rendered matches, in the visitor's timezone.
  (function () {
    const bar = document.getElementById("dayFilter");
    if (!bar) return;
    const cols = Array.from(document.querySelectorAll(".match-col"));
    const empty = document.getElementById("dayEmpty");
    const DAY = 86400000;

    // Translations + locale for date labels.
    const T = {
      all: "<%= t('day.all') %>", today: "<%= t('day.today') %>",
      yesterday: "<%= t('day.yesterday') %>", tomorrow: "<%= t('day.tomorrow') %>",
      matches: "<%= t('day.matches') %>", match: "<%= t('day.match') %>",
    };
    const LOCALE = { en: "en-GB", fr: "fr-FR", ar: "ar" }["<%= lang %>"] || "en-GB";

    // Day key in fixed GMT+1, formatted as YYYY-MM-DD (en-CA gives that order).
    const ymd = (ms) =>
      new Date(ms).toLocaleDateString("en-CA", { timeZone: "Etc/GMT-1" });

    const nowMs = Date.now();
    const todayKey = ymd(nowMs);
    const yKey = ymd(nowMs - DAY);
    const tomKey = ymd(nowMs + DAY);

    // Tag each card with its GMT+1 day key and count per day.
    const counts = {};
    cols.forEach((c) => {
      const key = ymd(Number(c.dataset.kickoff));
      c.dataset.daykey = key;
      counts[key] = (counts[key] || 0) + 1;
    });
    const keys = Object.keys(counts).sort();

    function label(key) {
      if (key === todayKey) return T.today;
      if (key === yKey) return T.yesterday;
      if (key === tomKey) return T.tomorrow;
      const [y, m, d] = key.split("-").map(Number);
      return new Date(y, m - 1, d).toLocaleDateString(LOCALE, {
        weekday: "short", month: "short", day: "numeric",
      });
    }

    function chip(text, sub, val) {
      const b = document.createElement("button");
      b.type = "button";
      b.className = "day-chip";
      b.dataset.day = val;
      b.innerHTML =
        '<span class="day-chip-main">' + text + "</span>" +
        '<span class="day-chip-sub">' + sub + "</span>";
      return b;
    }

    bar.appendChild(chip(T.all, cols.length + " " + T.matches, "all"));
    keys.forEach((k) =>
      bar.appendChild(chip(label(k), counts[k] + " " + (counts[k] > 1 ? T.matches : T.match), k))
    );

    function select(val, behavior) {
      let activeChip = null;
      bar.querySelectorAll(".day-chip").forEach((ch) => {
        const on = ch.dataset.day === val;
        ch.classList.toggle("active", on);
        if (on) activeChip = ch;
      });
      let shown = 0;
      cols.forEach((c) => {
        const vis = val === "all" || c.dataset.daykey === val;
        c.style.display = vis ? "" : "none";
        if (vis) shown++;
      });
      if (empty) empty.classList.toggle("d-none", shown !== 0);

      // Scroll the chosen chip to the center of the filter bar.
      if (activeChip) {
        activeChip.scrollIntoView({
          inline: "center",
          block: "nearest",
          behavior: behavior || "smooth",
        });
      }
    }

    bar.addEventListener("click", (e) => {
      const c = e.target.closest(".day-chip");
      if (c) select(c.dataset.day);
    });

    // Default to Today if it has matches, otherwise show everything.
    select(counts[todayKey] ? todayKey : "all", "auto");
  })();

  // If a match is LIVE, refresh periodically so the score stays current.
  if (document.querySelector(".badge-live")) {
    setTimeout(function () { location.reload(); }, 45000);
  }

  // Privacy toggle — blur/unblur the user's own predictions (remembered).
  (function () {
    const btn = document.getElementById("privacyToggle");
    if (!btn) return;
    function apply(hidden) {
      document.body.classList.toggle("preds-hidden", hidden);
      btn.querySelector("i").className = hidden ? "fa-solid fa-eye-slash" : "fa-solid fa-eye";
    }
    let hidden = localStorage.getItem("predsHidden") === "1";
    apply(hidden);
    btn.addEventListener("click", function () {
      hidden = !hidden;
      localStorage.setItem("predsHidden", hidden ? "1" : "0");
      apply(hidden);
    });
  })();

  // Dismiss announcements (remembered per device).
  document.querySelectorAll(".announcement").forEach(function (el) {
    const key = "annDismissed_" + el.dataset.id;
    if (localStorage.getItem(key)) { el.style.display = "none"; return; }
    el.querySelector(".btn-close").addEventListener("click", function () {
      el.style.display = "none";
      localStorage.setItem(key, "1");
    });
  });
</script>

<!-- Smooth AJAX prediction saving (no page reload) -->
<script>
  (function () {
    const T_UPDATE = "<%= t('dash.update') %>";

    function toast(msg, ok) {
      let box = document.getElementById("toastBox");
      if (!box) {
        box = document.createElement("div");
        box.id = "toastBox";
        box.className = "toast-box";
        document.body.appendChild(box);
      }
      const el = document.createElement("div");
      el.className = "toast-msg " + (ok ? "toast-ok" : "toast-err");
      el.textContent = msg;
      box.appendChild(el);
      requestAnimationFrame(() => el.classList.add("show"));
      setTimeout(() => { el.classList.remove("show"); setTimeout(() => el.remove(), 300); }, 2400);
    }

    document.querySelectorAll('form[action^="/dashboard/predict/"]').forEach(function (form) {
      form.addEventListener("submit", function (e) {
        e.preventDefault();
        const btn = form.querySelector("button");
        if (btn.disabled) return;
        const original = btn.innerHTML;
        btn.disabled = true;

        fetch(form.action, {
          method: "POST",
          headers: {
            "X-Requested-With": "XMLHttpRequest",
            "Accept": "application/json",
            "Content-Type": "application/x-www-form-urlencoded",
          },
          body: new URLSearchParams(new FormData(form)).toString(),
        })
          .then((r) => r.json())
          .then(function (j) {
            if (j.ok) {
              btn.innerHTML = '<i class="fa-solid fa-check me-1"></i>' + j.message;
              btn.classList.add("btn-saved");
              toast(j.message, true);
              setTimeout(function () {
                btn.innerHTML = '<i class="fa-solid fa-floppy-disk me-1"></i>' + T_UPDATE;
                btn.classList.remove("btn-saved");
                btn.disabled = false;
              }, 1500);
            } else {
              toast(j.message || "Error", false);
              btn.innerHTML = original;
              btn.disabled = false;
            }
          })
          .catch(function () {
            toast("Network error", false);
            btn.innerHTML = original;
            btn.disabled = false;
          });
      });
    });
  })();
</script>

<!-- All-predictions modal -->
<div class="modal fade" id="predsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered">
    <div class="modal-content wc-card border-0">
      <div class="modal-header">
        <h5 class="modal-title fw-bold" id="predsTitle"><%= t('mp.title') %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="predsBody"></div>
    </div>
  </div>
</div>

<script>
  (function () {
    const modalEl = document.getElementById("predsModal");
    const titleEl = document.getElementById("predsTitle");
    const bodyEl = document.getElementById("predsBody");
    const T = {
      title: "<%= t('mp.title') %>", pick: "<%= t('mp.pick') %>", player: "<%= t('lb.player') %>",
      pts: "<%= t('lb.points') %>", none: "<%= t('mp.none') %>", you: "<%= t('lb.you') %>",
      err: "<%= t('dash.lockedMsg') %>",
    };
    const ME = "<%= currentUser.username %>";
    function esc(s) {
      return String(s == null ? "" : s).replace(/[&<>"]/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
    }

    document.querySelectorAll(".see-all").forEach(function (btn) {
      btn.addEventListener("click", function () {
        bodyEl.innerHTML = '<div class="text-center text-secondary py-4"><i class="fa-solid fa-futbol fa-spin fa-2x"></i></div>';
        titleEl.textContent = T.title;
        bootstrap.Modal.getOrCreateInstance(modalEl).show();

        fetch("/match/" + btn.dataset.id + "/predictions.json")
          .then((r) => (r.ok ? r.json() : Promise.reject(r)))
          .then(function (j) {
            titleEl.textContent = T.title + " — " + esc(j.teamA) + " vs " + esc(j.teamB);
            if (!j.preds.length) {
              bodyEl.innerHTML = '<div class="text-center text-secondary py-4">' + esc(T.none) + "</div>";
              return;
            }
            let h = '<div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead><tr>' +
              '<th style="width:42px">#</th><th>' + esc(T.player) + '</th><th class="text-center">' + esc(T.pick) + "</th>" +
              (j.completed ? '<th class="text-end">' + esc(T.pts) + "</th>" : "") + "</tr></thead><tbody>";
            j.preds.forEach(function (p, i) {
              let pts = "";
              if (j.completed) {
                const b = p.pts === 2 ? "badge-done" : p.pts === 1 ? "badge-open" : "badge-locked";
                pts = '<td class="text-end"><span class="badge wc-badge ' + b + '">' + (p.pts > 0 ? "+" : "") + p.pts + "</span></td>";
              }
              const me = p.username === ME;
              const av = p.avatar ? '<img src="' + esc(p.avatar) + '" class="avatar-mini me-2" alt=""/>' : '';
              h += '<tr class="' + (me ? "row-me" : "") + '"><td class="text-secondary">' + (i + 1) + "</td>" +
                '<td class="fw-semibold">' + av + esc(p.username) + (me ? ' <span class="badge wc-userchip ms-1">' + esc(T.you) + "</span>" : "") + "</td>" +
                '<td class="text-center fw-bold">' + p.a + " - " + p.b + "</td>" + pts + "</tr>";
            });
            h += "</tbody></table></div>";
            bodyEl.innerHTML = h;
          })
          .catch(function () {
            bodyEl.innerHTML = '<div class="text-center text-danger py-4">' + esc(T.err) + "</div>";
          });
      });
    });
  })();
</script>

<%- include("partials/footer") %>
