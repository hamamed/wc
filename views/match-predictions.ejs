<%- include("partials/head", { title: "Predictions · WC 2026 Predictor" }) %>
<%- include("partials/navbar") %>

<%
  function fmtDate(d) {
    return d.toLocaleString("en-GB", {
      timeZone: "Etc/GMT-1", weekday: "short", month: "short", day: "numeric",
      hour: "2-digit", minute: "2-digit", hour12: false
    });
  }
  function mpPodium(list) {
    const esc = (s) => String(s == null ? "" : s).replace(/[&<>"]/g, (c) =>
      ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
    const tiers = [];
    for (let i = 0; i < list.length; i++) {
      const p = list[i];
      if (p.pts == null) break;
      const last = tiers[tiers.length - 1];
      if (last && last.pts === p.pts) { last.members.push(p); continue; }
      if (tiers.length >= 3) break;
      tiers.push({ place: tiers.length + 1, pts: p.pts, members: [p] });
    }
    if (!tiers.length) return "";
    const renderPlace = (tier) => {
      if (!tier) return "";
      const cls = tier.place === 1 ? "gold" : tier.place === 2 ? "silver" : "bronze";
      const members = tier.members.map((p) => {
        const ava = p.avatar
          ? '<img class="podium-avatar" src="' + esc(avatarSrc(p.avatar)) + '" alt=""/>'
          : '<span class="podium-avatar d-inline-flex align-items-center justify-content-center"><i class="fa-solid fa-user text-secondary"></i></span>';
        return '<div class="podium-member"><div class="podium-ava-wrap">' + ava +
          '<span class="medal medal-' + cls + ' podium-medal">' + tier.place + '</span></div>' +
          '<div class="podium-name">' + esc(p.username) + '</div></div>';
      }).join("");
      return '<div class="podium-place podium-' + tier.place + '"><div class="podium-members">' + members + '</div>' +
        '<div class="podium-points">+' + tier.pts + ' ' + esc(t('common.pts')) + '</div>' +
        '<div class="podium-bar">' + tier.place + '</div></div>';
    };
    const byPlace = (n) => tiers.find((tt) => tt.place === n);
    return '<div class="podium mb-0">' + renderPlace(byPlace(2)) + renderPlace(byPlace(1)) + renderPlace(byPlace(3)) + '</div>';
  }
%>

<div class="container py-4">
  <a href="/dashboard" class="btn btn-outline-secondary btn-sm mb-3">
    <i class="fa-solid fa-arrow-left me-1"></i> <%= t('nav.fixtures') %>
  </a>

  <!-- Match header -->
  <div class="card wc-card border-0 mb-4">
    <div class="card-body">
      <div class="text-center text-secondary small mb-2"><%= fmtDate(match.kickoffTime) %></div>
      <div class="d-flex align-items-center justify-content-between text-center">
        <div class="team w-100">
          <div class="team-flag">
            <% if (match.flagA) { %><img src="<%= match.flagA %>" class="flag-img" alt="" /><% } else { %><i class="fa-solid fa-shield-halved"></i><% } %>
          </div>
          <div class="fw-semibold mt-1"><%= tn(match.teamA) %></div>
        </div>
        <div class="vs px-2">
          <% if (match.completed) { %>
            <span class="final-score"><%= match.actualScoreA %>&nbsp;-&nbsp;<%= match.actualScoreB %></span>
          <% } else if (match.started) { %>
            <span class="live-score"><%= match.liveScoreA != null ? match.liveScoreA : 0 %>&nbsp;-&nbsp;<%= match.liveScoreB != null ? match.liveScoreB : 0 %></span>
          <% } else { %>
            <span class="text-secondary fw-bold"><%= t('common.vs') %></span>
          <% } %>
        </div>
        <div class="team w-100">
          <div class="team-flag">
            <% if (match.flagB) { %><img src="<%= match.flagB %>" class="flag-img" alt="" /><% } else { %><i class="fa-solid fa-shield-halved"></i><% } %>
          </div>
          <div class="fw-semibold mt-1"><%= tn(match.teamB) %></div>
        </div>
      </div>
    </div>
  </div>

  <% if (match.scored && preds.length) { %>
    <div class="card wc-card border-0 mb-4">
      <div class="card-body">
        <% if (match.live) { %><div class="text-center small text-danger fw-bold mb-2"><span class="live-dot"></span> <%= t('dash.badgeLive') %></div><% } %>
        <%- mpPodium(preds) %>
      </div>
    </div>
  <% } %>

  <h5 class="fw-semibold mb-3"><i class="fa-solid fa-people-group text-accent me-2"></i><%= t('mp.title') %> (<%= preds.length %>)</h5>

  <div class="card wc-card border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th class="ps-4" style="width:50px;">#</th>
            <th><%= t('lb.player') %></th>
            <th class="text-center"><%= t('mp.pick') %></th>
            <% if (match.scored) { %><th class="text-end pe-4"><%= t('lb.points') %></th><% } %>
          </tr>
        </thead>
        <tbody>
          <% if (preds.length === 0) { %>
            <tr><td colspan="4" class="text-center text-secondary py-4"><%= t('mp.none') %></td></tr>
          <% } %>
          <% preds.forEach(function (p, i) { %>
            <tr class="<%= p.username === currentUser.username ? 'row-me' : '' %>">
              <td class="ps-4 text-secondary"><%= match.scored ? p.rank : (i + 1) %></td>
              <td>
                <% if (p.avatar) { %>
                  <img src="<%= avatarSrc(p.avatar) %>" class="avatar-mini me-2" alt="" />
                <% } else { %>
                  <i class="fa-solid fa-user-circle text-secondary me-2"></i>
                <% } %>
                <span class="fw-semibold"><%= p.username %></span>
                <% if (p.username === currentUser.username) { %><span class="badge wc-userchip ms-2"><%= t('lb.you') %></span><% } %>
              </td>
              <td class="text-center fw-bold"><%= p.a %> - <%= p.b %></td>
              <% if (match.scored) { %>
                <td class="text-end pe-4">
                  <% if (p.pts === 4) { %><span class="badge wc-badge badge-done">+4</span>
                  <% } else if (p.pts === 2) { %><span class="badge wc-badge badge-open">+2</span>
                  <% } else if (p.pts === 1) { %><span class="badge wc-badge badge-open">+1</span>
                  <% } else { %><span class="badge wc-badge badge-locked">0</span><% } %>
                </td>
              <% } %>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include("partials/footer") %>
