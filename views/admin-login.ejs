<%- include("partials/head", { title: "Admin · WC 2026 Predictor" }) %>

<div class="login-hero d-flex align-items-center">
  <%- include("partials/iconPattern") %>
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-md-6 col-lg-4">
        <div class="text-center mb-4">
          <div class="login-logo mb-3"><i class="fa-solid fa-screwdriver-wrench"></i></div>
          <h1 class="fw-bold mb-1">Admin Panel</h1>
          <p class="text-secondary mb-0">Enter the admin password to manage results.</p>
        </div>

        <div class="card wc-card border-0 shadow-lg">
          <div class="card-body p-4 p-md-5">
            <% (error || []).forEach(function (msg) { %>
              <div class="alert alert-danger py-2"><%= msg %></div>
            <% }); %>
            <form action="/admin/login" method="POST">
              <div class="input-group input-group-lg mb-3">
                <span class="input-group-text"><i class="fa-solid fa-key"></i></span>
                <input type="password" name="password" class="form-control"
                       placeholder="Admin password" autofocus required />
              </div>
              <button class="btn btn-accent btn-lg w-100 fw-semibold">
                <i class="fa-solid fa-unlock me-1"></i> Enter
              </button>
            </form>
            <p class="text-center mt-3 mb-0">
              <a href="/dashboard" class="text-secondary small">&larr; Back to fixtures</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include("partials/footer") %>
