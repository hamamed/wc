<%- include("partials/head", { title: "Groups · WC 2026 Predictor" }) %>
<%- include("partials/navbar") %>

<%
  function flagCell(flag, team) {
    return (flag ? '<img src="' + flag + '" class="flag-mini" alt="" />' : '') + tn(team);
  }
%>

<div class="container py-4">
  <div class="mb-4">
    <h2 class="fw-bold mb-0"><i class="fa-solid fa-table-cells-large text-accent me-2"></i><%= t('st.title') %></h2>
    <p class="text-secondary mb-0"><%= t('st.subtitle') %></p>
  </div>

  <ul class="nav nav-pills mb-4" role="tablist">
    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-groups" type="button"><i class="fa-solid fa-layer-group me-1"></i><%= t('st.title') %></button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-ko" type="button"><i class="fa-solid fa-sitemap me-1"></i><%= t('ko.tab') %></button></li>
  </ul>

  <div class="tab-content">
  <div class="tab-pane fade show active" id="tab-groups" role="tabpanel">

  <% if (!groups || groups.length === 0 || groups.every(function(g){return g.rows.length===0})) { %>
    <div class="card wc-card border-0">
      <div class="card-body text-center text-secondary py-5">
        <i class="fa-solid fa-table-list fa-2x mb-3 d-block"></i>
        <%= t('st.none') %>
      </div>
    </div>
  <% } else { %>

  <!-- Group tables -->
  <div class="row g-3">
    <% groups.forEach(function (g) { %>
      <% if (g.rows.length) { %>
        <div class="col-12 col-lg-6">
          <div class="card wc-card border-0 h-100">
            <div class="card-body">
              <h6 class="fw-bold mb-3"><i class="fa-solid fa-layer-group text-accent me-2"></i><%= g.name %></h6>
              <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 standings-table">
                  <thead>
                    <tr>
                      <th style="width:34px;">#</th>
                      <th><%= t('st.team') %></th>
                      <th class="text-center" title="Played"><%= t('st.p') %></th>
                      <th class="text-center" title="Won"><%= t('st.w') %></th>
                      <th class="text-center" title="Drawn"><%= t('st.d') %></th>
                      <th class="text-center" title="Lost"><%= t('st.l') %></th>
                      <th class="text-center" title="Goal difference"><%= t('st.gd') %></th>
                      <th class="text-center" title="Points"><%= t('st.pts') %></th>
                    </tr>
                  </thead>
                  <tbody>
                    <% g.rows.forEach(function (r) { %>
                      <tr class="<%= r.rank <= 2 ? 'qualify' : (r.rank === 3 ? 'playoff' : '') %>">
                        <td class="fw-bold"><%= r.rank %></td>
                        <td class="fw-semibold"><%- flagCell(r.flag, r.team) %></td>
                        <td class="text-center"><%= r.played %></td>
                        <td class="text-center"><%= r.win %></td>
                        <td class="text-center"><%= r.draw %></td>
                        <td class="text-center"><%= r.lose %></td>
                        <td class="text-center"><%= r.gd > 0 ? '+' + r.gd : r.gd %></td>
                        <td class="text-center fw-bold text-accent"><%= r.points %></td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    <% }); %>
  </div>

  <!-- Best third-placed teams -->
  <% if (thirds && thirds.length) { %>
    <div class="card wc-card border-0 mt-4">
      <div class="card-body">
        <h6 class="fw-bold mb-1"><i class="fa-solid fa-ranking-star text-accent me-2"></i><%= t('st.bestThirds') %></h6>
        <p class="text-secondary small mb-3"><%= t('st.bestThirdsSub') %></p>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0 standings-table">
            <thead>
              <tr>
                <th style="width:34px;">#</th>
                <th><%= t('st.team') %></th>
                <th class="text-center"><%= t('st.p') %></th>
                <th class="text-center"><%= t('st.w') %></th>
                <th class="text-center"><%= t('st.d') %></th>
                <th class="text-center"><%= t('st.l') %></th>
                <th class="text-center"><%= t('st.gd') %></th>
                <th class="text-center"><%= t('st.pts') %></th>
              </tr>
            </thead>
            <tbody>
              <% thirds.forEach(function (r) { %>
                <tr class="<%= r.thirdRank <= 8 ? 'qualify' : '' %>">
                  <td class="fw-bold"><%= r.thirdRank %></td>
                  <td class="fw-semibold"><%- flagCell(r.flag, r.team) %></td>
                  <td class="text-center"><%= r.played %></td>
                  <td class="text-center"><%= r.win %></td>
                  <td class="text-center"><%= r.draw %></td>
                  <td class="text-center"><%= r.lose %></td>
                  <td class="text-center"><%= r.gd > 0 ? '+' + r.gd : r.gd %></td>
                  <td class="text-center fw-bold text-accent"><%= r.points %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Legend -->
  <div class="d-flex gap-3 flex-wrap small text-secondary mt-3">
    <span><span class="legend-box qualify"></span> <%= t('st.qualifies') %></span>
    <span><span class="legend-box playoff"></span> <%= t('st.third') %></span>
    <% if (source === "local") { %>
      <span class="ms-auto"><i class="fa-solid fa-circle-info me-1"></i><%= t('st.computed') %></span>
    <% } %>
  </div>

  <% } %>

  </div><!-- /tab-groups -->

  <div class="tab-pane fade" id="tab-ko" role="tabpanel">
    <% if (!bracket || !bracket.rounds || !bracket.rounds.some(function(r){return r.matches.length;})) { %>
      <div class="card wc-card border-0"><div class="card-body text-center text-secondary py-5"><i class="fa-solid fa-sitemap fa-2x mb-3 d-block"></i><%= t('ko.empty') %></div></div>
    <% } else { %>
      <% if (bracket.provisional) { %><p class="text-secondary small mb-3"><i class="fa-solid fa-circle-info me-1"></i><%= t('ko.provisional') %></p><% } %>

      <%
        // A single match-cell = two stacked flag dots (used by the desktop tree).
        function dot(flag, win, label) {
          return '<span class="kt-dot' + (flag ? '' : ' tbd') + (win ? ' win' : '') + '" title="' + (label || '') + '">' +
            (flag ? '<img src="' + flag + '" alt="" />' : '') + '</span>';
        }
        function ktMatch(m) {
          return '<div class="kt-m"><div class="kt-cell">' +
            dot(m.flagA, m.winA, (m.teamA || m.labelA || '')) +
            dot(m.flagB, m.winB, (m.teamB || m.labelB || '')) + '</div></div>';
        }
        function ktCol(rd) {
          return '<div class="kt-col">' + rd.matches.map(ktMatch).join('') + '</div>';
        }
        function ktRow(name, flag, score, win, rank) {
          return '<div class="kt-fr' + (win ? ' win' : '') + '">' +
            (rank ? '<span class="kt-rk">' + rank + '</span>' : '') +
            (flag ? '<img class="ko-flag" src="' + flag + '" alt=""/>' : '<span class="ko-flag kt-noflag"></span>') +
            '<span class="nm">' + (name || '—') + '</span>' +
            (score != null ? '<span class="sc">' + score + '</span>' : '') + '</div>';
        }
        function finalCard(m) {
          if (!m) return '';
          var champ = m.winA ? (m.teamA || '') : (m.winB ? (m.teamB || '') : '');
          return '<div class="kt-final">' +
            '<div class="kt-final-ttl"><i class="fa-solid fa-trophy"></i> FINAL</div>' +
            ktRow(m.teamA || m.labelA, m.flagA, m.scoreA, m.winA) +
            ktRow(m.teamB || m.labelB, m.flagB, m.scoreB, m.winB) +
            (champ ? '<div class="kt-champ"><i class="fa-solid fa-crown me-1"></i>' + champ + '</div>' : '') +
            '</div>';
        }
        function thirdCard(m) {
          if (!m) return '';
          // winner = 3rd, loser = 4th (once played)
          var aRank = m.winA ? '3rd' : (m.winB ? '4th' : '');
          var bRank = m.winB ? '3rd' : (m.winA ? '4th' : '');
          return '<div class="kt-third">' +
            '<div class="kt-third-ttl">3rd place play-off</div>' +
            ktRow(m.teamA || m.labelA, m.flagA, m.scoreA, m.winA, aRank) +
            ktRow(m.teamB || m.labelB, m.flagB, m.scoreB, m.winB, bRank) +
            '</div>';
        }
      %>

      <!-- Desktop: bracket tree -->
      <div class="kt d-none d-lg-flex">
        <div class="kt-half kt-left">
          <% bracket.tree.left.forEach(function (rd) { %><%- ktCol(rd) %><% }); %>
        </div>
        <div class="kt-col kt-center">
          <%- finalCard(bracket.tree.final) %>
          <%- thirdCard(bracket.tree.third) %>
        </div>
        <div class="kt-half kt-right">
          <% bracket.tree.right.slice().reverse().forEach(function (rd) { %><%- ktCol(rd) %><% }); %>
        </div>
      </div>

      <!-- Mobile: stacked round-by-round cards -->
      <div class="d-lg-none">
        <% bracket.rounds.forEach(function (rd) { %>
          <div class="ko-round">
            <div class="ko-round-head"><h6 class="fw-bold mb-0"><%= rd.name %></h6></div>
            <div class="ko-grid">
              <% rd.matches.forEach(function (m) { %>
                <div class="ko-match">
                  <div class="ko-num">Match <%= m.n %></div>
                  <div class="ko-team <%= m.winA ? 'win' : '' %>">
                    <% if (m.flagA) { %><img class="ko-flag" src="<%= m.flagA %>" alt="" /><% } %>
                    <span class="nm"><%= m.teamA || m.labelA || '—' %></span>
                    <% if (m.scoreA != null) { %><span class="sc"><%= m.scoreA %></span><% } %>
                  </div>
                  <div class="ko-team <%= m.winB ? 'win' : '' %>">
                    <% if (m.flagB) { %><img class="ko-flag" src="<%= m.flagB %>" alt="" /><% } %>
                    <span class="nm"><%= m.teamB || m.labelB || '—' %></span>
                    <% if (m.scoreB != null) { %><span class="sc"><%= m.scoreB %></span><% } %>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div><!-- /tab-ko -->
  </div><!-- /tab-content -->
</div>

<%- include("partials/footer") %>
