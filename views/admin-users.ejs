<%- include("partials/head", { title: "Admin · Users" }) %>
<%- include("partials/navbar") %>

<%
  function fmtDate(d) {
    if (!d) return "—";
    return d.toLocaleString("en-GB", {
      timeZone: "Etc/GMT-1",
      year: "numeric", month: "short", day: "numeric",
      hour: "2-digit", minute: "2-digit", hour12: false
    });
  }
%>

<div class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
      <h2 class="fw-bold mb-0"><i class="fa-solid fa-users text-accent me-2"></i>Users</h2>
      <p class="text-secondary mb-0"><%= users.length %> registered user<%= users.length === 1 ? "" : "s" %> (times in GMT+1).</p>
    </div>
    <a href="/admin" class="btn btn-outline-secondary btn-sm">
      <i class="fa-solid fa-arrow-left me-1"></i> Back to admin
    </a>
  </div>

  <div class="card wc-card border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th class="ps-4">User</th>
            <th>Signed up</th>
            <th class="text-center">Points</th>
            <th>Champion</th>
            <th class="text-end pe-4">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (users.length === 0) { %>
            <tr><td colspan="5" class="text-center text-secondary py-4">No users yet.</td></tr>
          <% } %>
          <% users.forEach(function (u) { %>
            <tr>
              <td class="ps-4">
                <form action="/admin/users/rename/<%= u.id %>" method="POST"
                      class="d-flex align-items-center gap-2">
                  <input type="text" name="username" value="<%= u.username %>"
                         class="form-control form-control-sm" style="max-width:180px;" required />
                  <button class="btn btn-outline-secondary btn-sm" title="Rename">
                    <i class="fa-solid fa-pen"></i>
                  </button>
                </form>
              </td>
              <td class="text-secondary small"><%= fmtDate(u.createdAt) %></td>
              <td class="text-center fw-bold text-accent"><%= u.totalPoints %></td>
              <td class="small">
                <% if (u.championPick) { %><%= u.championPick %><% } else { %><span class="text-secondary">—</span><% } %>
              </td>
              <td class="text-end pe-4">
                <div class="d-flex justify-content-end gap-2">
                  <form action="/admin/users/reset/<%= u.id %>" method="POST"
                        onsubmit="return confirm('Reset this user\'s points to 0?');">
                    <button class="btn btn-outline-secondary btn-sm" title="Reset points">
                      <i class="fa-solid fa-rotate-left"></i>
                    </button>
                  </form>
                  <form action="/admin/users/delete/<%= u.id %>" method="POST"
                        onsubmit="return confirm('Delete this user and all their predictions? This cannot be undone.');">
                    <button class="btn btn-outline-danger btn-sm" title="Delete user">
                      <i class="fa-solid fa-trash"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include("partials/footer") %>
