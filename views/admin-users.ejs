<%- include("partials/head", { title: "Admin · Users" }) %>
<%- include("partials/navbar") %>

<%
  function fmtDate(d) {
    if (!d) return "—";
    return d.toLocaleString("en-GB", {
      timeZone: "Etc/GMT-1",
      year: "numeric", month: "short", day: "numeric",
      hour: "2-digit", minute: "2-digit", hour12: false
    });
  }
%>

<div class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
      <h2 class="fw-bold mb-0"><i class="fa-solid fa-users text-accent me-2"></i>Users</h2>
      <p class="text-secondary mb-0"><%= users.length %> registered user<%= users.length === 1 ? "" : "s" %> (times in GMT+1).</p>
    </div>
    <a href="/admin" class="btn btn-outline-secondary btn-sm">
      <i class="fa-solid fa-arrow-left me-1"></i> Back to admin
    </a>
  </div>

  <div class="card wc-card border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th class="ps-4">User</th>
            <th>Signed up</th>
            <th class="text-center">Points</th>
            <th>Champion</th>
            <th class="text-end pe-4">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (users.length === 0) { %>
            <tr><td colspan="5" class="text-center text-secondary py-4">No users yet.</td></tr>
          <% } %>
          <% users.forEach(function (u) { %>
            <tr>
              <td class="ps-4">
                <form action="/admin/users/rename/<%= u.id %>" method="POST"
                      class="d-flex align-items-center gap-2">
                  <input type="text" name="username" value="<%= u.username %>"
                         class="form-control form-control-sm" style="max-width:180px;" required />
                  <button class="btn btn-outline-secondary btn-sm" title="Rename">
                    <i class="fa-solid fa-pen"></i>
                  </button>
                  <% if (u.isAdmin) { %>
                    <span class="badge text-bg-warning"><i class="fa-solid fa-shield-halved me-1"></i>Admin</span>
                  <% } %>
                </form>
              </td>
              <td class="text-secondary small"><%= fmtDate(u.createdAt) %></td>
              <td class="text-center fw-bold text-accent"><%= u.totalPoints %></td>
              <td class="small">
                <% if (u.championPick) { %><%= u.championPick %><% } else { %><span class="text-secondary">—</span><% } %>
              </td>
              <td class="text-end pe-4">
                <div class="d-flex justify-content-end gap-2">
                  <button type="button" class="btn btn-outline-secondary btn-sm view-preds"
                          data-id="<%= u.id %>" data-name="<%= u.username %>" title="View predictions">
                    <i class="fa-solid fa-list-check"></i>
                  </button>
                  <form action="/admin/users/admin/<%= u.id %>" method="POST"
                        onsubmit="return confirm('<%= u.isAdmin ? "Remove admin access from this user?" : "Grant admin access to this user?" %>');">
                    <button class="btn btn-sm <%= u.isAdmin ? 'btn-warning' : 'btn-outline-warning' %>"
                            title="<%= u.isAdmin ? 'Revoke admin' : 'Make admin' %>">
                      <i class="fa-solid fa-shield-halved"></i>
                    </button>
                  </form>
                  <form action="/admin/users/resetpin/<%= u.id %>" method="POST"
                        onsubmit="return confirm('Clear this user\'s PIN? They will set a new one next login.');">
                    <button class="btn btn-outline-secondary btn-sm" title="Reset PIN (unlock)">
                      <i class="fa-solid fa-key"></i>
                    </button>
                  </form>
                  <form action="/admin/users/reset/<%= u.id %>" method="POST"
                        onsubmit="return confirm('Reset this user\'s points to 0?');">
                    <button class="btn btn-outline-secondary btn-sm" title="Reset points">
                      <i class="fa-solid fa-rotate-left"></i>
                    </button>
                  </form>
                  <form action="/admin/users/delete/<%= u.id %>" method="POST"
                        onsubmit="return confirm('Delete this user and all their predictions? This cannot be undone.');">
                    <button class="btn btn-outline-danger btn-sm" title="Delete user">
                      <i class="fa-solid fa-trash"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Predictions modal -->
<div class="modal fade" id="predsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
    <div class="modal-content wc-card border-0">
      <div class="modal-header">
        <h5 class="modal-title fw-bold" id="predsTitle">Predictions</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="predsLoading" class="text-center text-secondary py-4">
          <i class="fa-solid fa-spinner fa-spin me-1"></i> Loading…
        </div>
        <div class="table-responsive d-none" id="predsWrap">
          <table class="table table-hover align-middle mb-0">
            <thead>
              <tr>
                <th>Match</th>
                <th class="text-center">Pick</th>
                <th class="text-center">Result</th>
                <th class="text-end">Pts</th>
              </tr>
            </thead>
            <tbody id="predsBody"></tbody>
          </table>
        </div>
        <div id="predsEmpty" class="text-center text-secondary py-4 d-none">No predictions yet.</div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const modalEl = document.getElementById("predsModal");
    const title = document.getElementById("predsTitle");
    const loading = document.getElementById("predsLoading");
    const wrap = document.getElementById("predsWrap");
    const empty = document.getElementById("predsEmpty");
    const body = document.getElementById("predsBody");

    function esc(s) {
      return String(s).replace(/[&<>"]/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
    }

    document.querySelectorAll(".view-preds").forEach(function (btn) {
      btn.addEventListener("click", function () {
        title.textContent = btn.dataset.name + " — predictions";
        loading.classList.remove("d-none");
        wrap.classList.add("d-none");
        empty.classList.add("d-none");
        body.innerHTML = "";
        bootstrap.Modal.getOrCreateInstance(modalEl).show();

        fetch("/admin/users/" + btn.dataset.id + "/predictions")
          .then((r) => r.json())
          .then(function (j) {
            loading.classList.add("d-none");
            if (!j.predictions || j.predictions.length === 0) {
              empty.classList.remove("d-none");
              return;
            }
            j.predictions.forEach(function (p) {
              const tr = document.createElement("tr");
              tr.innerHTML =
                '<td>' + esc(p.match) + '</td>' +
                '<td class="text-center fw-semibold">' + esc(p.pick) + '</td>' +
                '<td class="text-center">' + esc(p.result) + '</td>' +
                '<td class="text-end fw-bold text-accent">' + esc(p.points) + '</td>';
              body.appendChild(tr);
            });
            wrap.classList.remove("d-none");
          })
          .catch(function () {
            loading.classList.add("d-none");
            empty.textContent = "Failed to load.";
            empty.classList.remove("d-none");
          });
      });
    });
  })();
</script>

<%- include("partials/footer") %>
