<%- include("partials/head", { title: "Login · WC 2026 Predictor" }) %>

<div class="login-hero d-flex align-items-center">
  <%- include("partials/iconPattern") %>
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-md-7 col-lg-5">

        <div class="text-center mb-2">
          <% langs.forEach(function (l) { %>
            <a href="/lang/<%= l.code %>" class="btn btn-sm <%= l.code === lang ? 'btn-accent' : 'btn-outline-secondary' %> me-1"><%= l.code.toUpperCase() %></a>
          <% }); %>
        </div>

        <div class="text-center mb-4">
          <img src="/logo.png" alt="HAMA World Cup Predictor 2026" class="login-logo-img mb-3" />
          <p class="text-secondary mb-0"><%= t('login.tagline') %></p>
        </div>

        <div class="card wc-card border-0 shadow-lg">
          <div class="card-body p-4 p-md-5">

            <!-- Flash messages on the login screen -->
            <% (success || []).forEach(function (msg) { %>
              <div class="alert alert-success py-2"><%= msg %></div>
            <% }); %>
            <% (error || []).forEach(function (msg) { %>
              <div class="alert alert-danger py-2"><%= msg %></div>
            <% }); %>

            <h5 class="fw-semibold mb-3">
              <i class="fa-solid fa-user-astronaut text-accent me-2"></i><%= t('login.enterUsername') %>
            </h5>
            <p class="text-secondary small mb-4">
              <%= t('login.noPassword') %>
            </p>

            <form action="/login" method="POST">
              <div class="input-group input-group-lg mb-3">
                <span class="input-group-text"><i class="fa-solid fa-at"></i></span>
                <input
                  type="text"
                  name="username"
                  class="form-control"
                  placeholder="<%= t('login.placeholder') %>"
                  autocomplete="off"
                  autofocus
                  required
                />
              </div>
              <button type="submit" class="btn btn-accent btn-lg w-100 fw-semibold">
                <%= t('login.play') %> <i class="fa-solid fa-arrow-right-long ms-1"></i>
              </button>
            </form>

          </div>
        </div>

        <p class="text-center text-secondary small mt-4 mb-0">
          <%= t('login.hint') %>
        </p>

      </div>
    </div>
  </div>
</div>

<%- include("partials/footer") %>
